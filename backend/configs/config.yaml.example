server:
  name: aicook-backend
  http:
    addr: 0.0.0.0:8000
    timeout: 300s
  grpc:
    addr: 0.0.0.0:9000
    timeout: 1000s

data:
  pg_database:
    host: sshjd.aihelper.chat
    port: 30532
    user: 
    password: 
    dbname: pgdb
    sslmode: disable
    schema: aicook
    auto_migrate: true
  redis:
    addr: sshjd.aihelper.chat:30379
    read_timeout: 0.2s
    write_timeout: 0.2s
    password: "rediscj123456"

oss:
  # endpoint 供后端直连 MinIO；public_endpoint 供前端访问预签名 URL 和对象资源。
  endpoint: sshjd.aihelper.chat:30990
  public_endpoint: http://sshjd.aihelper.chat:30990
  access_key: ""
  secret_key: ""
  use_ssl: false
  media_bucket: aicook-media
  knowledge_bucket: aicook-kb

inference:
  endpoint: http://127.0.0.1:8088
  timeout: 30s

ai:
  mode: adk
  # Xiaomi MiMo 兼容 OpenAI Chat Completions。
  provider: xiaomi
  base_url: "https://api.xiaomimimo.com/v1"
  api_key: "sk-"
  # base_url: "https://token-plan-cn.xiaomimimo.com/v1"
  # api_key: "tp-"
  # 纯文本默认走轻量文本模型。
  chat_model: "mimo-v2-pro" # mimo-v2-pro
  # 上传图片/音频/文件时自动切到多模态模型。
  vision_model: "mimo-v2-omni"
  embedding:
    provider:
      doubao:
        base_url: "https://ark.cn-beijing.volces.com/api/v3"
        model: "doubao-embedding-vision-251215"
        api_key: "your-doubao-api-key"
        api_type: "multimodal"
        dimensions: 2048
