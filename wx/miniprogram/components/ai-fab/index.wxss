.ai-fab {
  position: fixed;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(255, 122, 0, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 90;
  border: 4rpx solid #FFE4C9;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
  /* V11: GPU 合成层减少拖拽抖动 */
  will-change: transform, left, top;
}

.ai-fab--dragging {
  transform: scale(1.1);
  box-shadow: 0 16rpx 40rpx rgba(255, 122, 0, 0.46);
  transition: transform 0.12s ease;
}

.ai-fab__img {
  width: 88rpx;
  height: 88rpx;
}

/* V11: 招呼气泡（每次 onShow 触发，3.5s 自动消失）
 * 气泡贴浮球内侧边缘展开，朝屏幕中间方向延伸，避免溢出屏幕：
 *   .ai-fab--side-right → 浮球在右半屏，气泡 right:0（向左展开），尖角在右
 *   .ai-fab--side-left  → 浮球在左半屏，气泡 left:0（向右展开），尖角在左
 */
.ai-fab__bubble {
  position: absolute;
  bottom: calc(100% + 14rpx);
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF6EE 100%);
  border-radius: 24rpx;
  padding: 14rpx 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 27, 22, 0.14);
  border: 2rpx solid #FFE4C9;
  white-space: nowrap;
  animation: ai-fab-bubble-in 0.32s cubic-bezier(0.32, 1.4, 0.6, 1);
  pointer-events: none;
  /* 限制最大宽度，超长内容也不会撑爆 */
  max-width: 480rpx;
}

/* 默认右侧（浮球在右半屏）：气泡靠浮球右边对齐，向左展开 */
.ai-fab--side-right .ai-fab__bubble {
  right: 0;
}
.ai-fab--side-right .ai-fab__bubble::after {
  right: 36rpx;
  left: auto;
}

/* 左侧（浮球在左半屏）：气泡靠浮球左边对齐，向右展开 */
.ai-fab--side-left .ai-fab__bubble {
  left: 0;
}
.ai-fab--side-left .ai-fab__bubble::after {
  left: 36rpx;
  right: auto;
}

.ai-fab__bubble-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #1F1B16;
  line-height: 1.3;
}

/* 气泡尖角（基础） */
.ai-fab__bubble::after {
  content: '';
  position: absolute;
  top: 100%;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #FFF6EE;
  margin-top: -2rpx;
}

@keyframes ai-fab-bubble-in {
  0%   { opacity: 0; transform: translateY(8rpx) scale(0.9); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}
