.ai-fab {
  position: fixed;
  right: 32rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(255, 122, 0, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 90;
  border: 4rpx solid #FFE4C9;
}

.ai-fab__img {
  width: 88rpx;
  height: 88rpx;
}
