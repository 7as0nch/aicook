<view class="ais-mask {{sheetVisible ? 'ais-mask--visible' : 'ais-mask--no-anim'}}" bindtap="onMaskTap">
  <view
    class="ais {{sheetExpanded ? 'ais--expanded' : ''}} {{dragging ? 'ais--dragging' : ''}} {{!sheetVisible ? 'ais--no-anim' : ''}}"
    style="{{sheetStyle}}"
    catchtap="onSheetTap"
  >
    <!-- 拖拽区：包含 handle + head 整个顶部，方便用户从任何位置拖动 -->
    <view
      class="ais__top"
      bindtouchstart="onDragStart"
      catchtouchmove="onDragMove"
      bindtouchend="onDragEnd"
      bindtouchcancel="onDragEnd"
    >
      <view class="ais__handle"></view>

      <view class="ais__head">
        <view class="ais__title">
          <mascot-bubble state="smile" size="sm" />
          <view class="ais__title-text">
            <text class="ais__title-main">厨艺助理 AI</text>
            <view class="ais__title-sub">
              <text class="ais__dot">●</text>
              <text>在线 · 随时为你出主意</text>
            </view>
          </view>
        </view>
        <view class="ais__head-actions">
          <view class="ais__icon-btn {{historyVisible ? 'ais__icon-btn--active' : ''}}" catchtap="onOpenHistory">
            <image class="ais__icon-btn-img" src="/assets/icons/clock.png" mode="aspectFit" />
          </view>
          <view class="ais__icon-btn" catchtap="onToggleExpand">
            <image class="ais__icon-btn-img" src="{{sheetExpanded ? '/assets/icons/collapse.svg' : '/assets/icons/expand.svg'}}" mode="aspectFit" />
          </view>
          <view class="ais__icon-btn" catchtap="onClose">
            <image class="ais__icon-btn-img" src="/assets/icons/close.svg" mode="aspectFit" />
          </view>
        </view>
      </view>
    </view>

    <!-- 历史浮窗（mini popover，相对 ais 容器） -->
    <view wx:if="{{historyVisible}}" class="ais__history-pop">
      <view class="ais__history-arrow"></view>
      <view class="ais__history-head">
        <text class="ais__history-title">最近会话</text>
        <text class="ais__history-new" catchtap="onNewFromHistory">+ 新建</text>
      </view>
      <view wx:if="{{historyLoading && !historyList.length}}" class="ais__history-empty">加载中…</view>
      <view wx:elif="{{!historyList.length}}" class="ais__history-empty">暂无历史</view>
      <scroll-view scroll-y class="ais__history-list">
        <view
          wx:for="{{historyList}}"
          wx:key="id"
          class="ais__history-row"
          data-id="{{item.id}}"
          catchtap="onPickHistory"
        >
          <view class="ais__history-row-body">
            <text class="ais__history-row-title">{{item.title}}</text>
            <text class="ais__history-row-meta">{{item.sceneLabel}}</text>
          </view>
          <text class="ais__history-row-time">{{item.timeLabel}}</text>
        </view>
      </scroll-view>
    </view>
    <view wx:if="{{historyVisible}}" class="ais__history-mask" catchtap="onCloseHistory"></view>

    <scroll-view class="ais__body" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}" scroll-into-view="{{scrollToView}}">
      <!-- 上次会话恢复卡（24h 内有未关闭的会话时显示） -->
      <view wx:if="{{resumeCard && !messages.length}}" class="ais__resume">
        <view class="ais__resume-info">
          <view class="ais__resume-label">检测到你上次还有会话</view>
          <view class="ais__resume-title">{{resumeCard.title}}</view>
          <view class="ais__resume-time">{{resumeCard.timeLabel}}</view>
        </view>
        <view class="ais__resume-actions">
          <view class="ais__resume-dismiss" catchtap="onDismissResume">新开</view>
          <view class="ais__resume-cta" catchtap="onResumeLast">继续 ›</view>
        </view>
      </view>

      <!-- 空态（无消息）：mascot greeting + 2x2 quick + 3 suggestions -->
      <block wx:if="{{!messages.length}}">
        <view class="ais__greet">
          <mascot-bubble
            state="default"
            size="md"
            text="你好！我是你的厨艺助理 👋 不知道吃什么？拍张冰箱照，我来帮你出主意～"
          />
        </view>

        <view class="ais__quick">
          <view
            wx:for="{{quickActions}}"
            wx:key="id"
            class="ais__quick-card"
            data-id="{{item.id}}"
            bindtap="onQuickTap"
          >
            <view class="ais__quick-icon">
              <image class="ais__quick-icon-img" src="{{item.iconSrc}}" mode="aspectFit" />
            </view>
            <view class="ais__quick-text">
              <text class="ais__quick-label">{{item.label}}</text>
              <text class="ais__quick-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>

        <view class="ais__suggest-head">
          <text>✦ 你也可以这样问我</text>
        </view>
        <view class="ais__suggest-list">
          <view
            wx:for="{{suggestions}}"
            wx:key="*this"
            class="ais__suggest-item"
            data-text="{{item}}"
            bindtap="onSuggestionTap"
          >
            <text class="ais__suggest-text">{{item}}</text>
            <text class="ais__suggest-arrow">›</text>
          </view>
        </view>
      </block>

      <!-- 有消息态：消息列表 -->
      <block wx:else>
        <view
          wx:for="{{messages}}"
          wx:key="client_id"
          wx:for-item="msg"
          wx:if="{{msg.segments.length || msg.status === 'streaming' || msg.flow_count}}"
          id="m-{{msg.client_id}}"
          class="ais__msg ais__msg--{{msg.role}}"
        >
          <view wx:if="{{msg.role === 'assistant'}}" class="ais__msg-avatar">
            <image class="ais__msg-avatar-img" src="/assets/mascot/bao-default.png" mode="aspectFit" />
          </view>
          <view class="ais__msg-col">
            <view class="ais__msg-bubble">
              <block wx:for="{{msg.segments}}" wx:for-item="seg" wx:key="index">
                <block wx:if="{{seg.kind === 'text'}}">
                  <rich-text wx:if="{{seg.nodes}}" class="ais__msg-rich" nodes="{{seg.nodes}}" />
                  <view wx:else class="ais__msg-text">{{seg.content}}</view>
                </block>
                <view wx:elif="{{seg.kind === 'reasoning'}}" class="ais__msg-reason">
                  <view class="ais__msg-reason-head" data-cid="{{msg.client_id}}" catchtap="onReasonToggle">
                    <view class="ais__msg-reason-dot"></view>
                    <text class="ais__msg-reason-label">💭 推理过程</text>
                    <text class="ais__msg-reason-chevron">{{msg.reasoning_collapsed ? '展开 ▸' : '收起 ▾'}}</text>
                  </view>
                  <text wx:if="{{!msg.reasoning_collapsed}}" class="ais__msg-reason-text">{{seg.content}}</text>
                </view>
                <view wx:elif="{{seg.kind === 'recipe_card'}}" class="ais__msg-recipe" data-id="{{seg.recipe_id}}" data-cid="{{msg.client_id}}" data-idx="{{index}}" bindtap="onRecipeCardTap">
                  <view wx:if="{{seg.cover_image_url}}" class="ais__msg-recipe-cover">
                    <image class="ais__msg-recipe-cover-img" src="{{seg.cover_image_url}}" mode="aspectFill" />
                  </view>
                  <view class="ais__msg-recipe-body">
                    <view class="ais__msg-recipe-title">{{seg.title}}</view>
                    <view wx:if="{{seg.summary}}" class="ais__msg-recipe-sum">{{seg.summary}}</view>
                    <view class="ais__msg-recipe-cta">{{seg.recipe_id ? '查看详情 ›' : '✎ 编辑并保存 ›'}}</view>
                  </view>
                </view>
                <view wx:elif="{{seg.kind === 'approval'}}" class="ais__msg-approval">
                  <text class="ais__msg-approval-prompt">{{seg.prompt}}</text>
                  <view wx:if="{{seg.options.length}}" class="ais__msg-approval-opts">
                    <view
                      wx:for="{{seg.options}}"
                      wx:for-item="opt"
                      wx:key="id"
                      class="ais__msg-approval-opt {{seg.selected_map[opt.id] ? 'ais__msg-approval-opt--on' : ''}} {{seg.answered ? 'ais__msg-approval-opt--done' : ''}}"
                      data-cid="{{msg.client_id}}"
                      data-aid="{{seg.approval_id}}"
                      data-oid="{{opt.id}}"
                      catchtap="onApprovalOptionTap"
                    >
                      <text class="ais__msg-approval-opt-title">{{opt.title}}</text>
                      <text wx:if="{{opt.summary}}" class="ais__msg-approval-opt-sum">{{opt.summary}}</text>
                    </view>
                  </view>
                  <view wx:if="{{!seg.answered && (seg.selection_mode === 'multi' || seg.allow_skip)}}" class="ais__msg-approval-actions">
                    <view
                      wx:if="{{seg.allow_skip}}"
                      class="ais__msg-approval-skip"
                      data-cid="{{msg.client_id}}"
                      data-aid="{{seg.approval_id}}"
                      catchtap="onApprovalSkip"
                    >跳过</view>
                    <view
                      wx:if="{{seg.selection_mode === 'multi'}}"
                      class="ais__msg-approval-confirm"
                      data-cid="{{msg.client_id}}"
                      data-aid="{{seg.approval_id}}"
                      catchtap="onApprovalConfirm"
                    >确认选择</view>
                  </view>
                  <view wx:if="{{seg.answered}}" class="ais__msg-approval-answered">✓ 已选择{{seg.selected_label ? '：' + seg.selected_label : ''}}</view>
                </view>
                <view wx:elif="{{seg.kind === 'sources'}}" class="ais__msg-sources">
                  <text class="ais__msg-sources-head">🔎 参考来源（{{seg.sources.length}}）</text>
                  <view
                    wx:for="{{seg.sources}}"
                    wx:for-item="src"
                    wx:key="title"
                    class="ais__msg-source"
                  >
                    <text class="ais__msg-source-title">{{src.title}}</text>
                    <text wx:if="{{src.snippet}}" class="ais__msg-source-snippet">{{src.snippet}}</text>
                    <text wx:if="{{src.site_name}}" class="ais__msg-source-site">{{src.site_name}}</text>
                  </view>
                </view>
                <view wx:elif="{{seg.kind === 'error'}}" class="ais__msg-error">⚠ {{seg.message}}</view>
              </block>
              <view wx:if="{{msg.status === 'streaming' && !msg.segments.length}}" class="ais__msg-typing">
                <view class="ais__msg-typing-dot"></view>
                <view class="ais__msg-typing-dot"></view>
                <view class="ais__msg-typing-dot"></view>
              </view>
            </view>
            <!-- 工作流时间线（tool_call / agent / status）：默认折叠，头部计数 + 流式中实时行 -->
            <view wx:if="{{msg.role === 'assistant' && msg.flow_count}}" class="ais__msg-flowline">
              <view class="ais__msg-flow-head" data-cid="{{msg.client_id}}" catchtap="onFlowToggle">
                <text class="ais__msg-flow-head-icon">⚙️</text>
                <text class="ais__msg-flow-head-text">执行过程 · {{msg.flow_count}} 步</text>
                <text class="ais__msg-flow-head-chevron">{{msg.flow_collapsed ? '展开 ▸' : '收起 ▾'}}</text>
              </view>
              <view wx:if="{{msg.flow_collapsed && msg.status === 'streaming' && msg.flow_live}}" class="ais__msg-flow">
                <view class="ais__msg-flow-dot ais__msg-flow-dot--running"></view>
                <text>{{msg.flow_live}}</text>
              </view>
              <block wx:if="{{!msg.flow_collapsed}}">
                <block wx:for="{{msg.segments}}" wx:for-item="seg" wx:key="index">
                  <view wx:if="{{seg.kind === 'tool_call'}}" class="ais__msg-flow">
                    <view class="ais__msg-flow-dot {{seg.status === 'running' ? 'ais__msg-flow-dot--running' : ''}}"></view>
                    <text>调用 {{seg.tool_name}}</text>
                  </view>
                  <view wx:elif="{{seg.kind === 'agent'}}" class="ais__msg-flow">
                    <view class="ais__msg-flow-dot ais__msg-flow-dot--agent {{seg.status === 'running' ? 'ais__msg-flow-dot--running' : ''}}"></view>
                    <text>{{seg.content}}</text>
                  </view>
                  <view wx:elif="{{seg.kind === 'status'}}" class="ais__msg-flow">
                    <view class="ais__msg-flow-dot ais__msg-flow-dot--status {{seg.status === 'running' ? 'ais__msg-flow-dot--running' : ''}}"></view>
                    <text>{{seg.message}}</text>
                  </view>
                </block>
              </block>
            </view>
          </view>
        </view>

        <view wx:if="{{streaming}}" class="ais__stop" bindtap="onAbort">停止生成</view>
      </block>
    </scroll-view>

    <!-- mode chip -->
    <view class="ais__modes">
      <mode-chip dotColor="#FF7A00" label="深度思考" active="{{reasoningEnabled}}" bind:toggle="onToggleReasoning" />
      <mode-chip dotColor="#2DBE7A" label="联网搜索" active="{{webSearchEnabled}}" bind:toggle="onToggleWebSearch" />
      <mode-chip dotColor="#9B978F" label="图文识别" active="{{imageRecipeEnabled}}" bind:toggle="onToggleImageRecipe" />
    </view>

    <!-- 输入条 -->
    <view class="ais__input">
      <view class="ais__input-mic {{recording ? 'ais__input-mic--rec' : ''}}" bindtap="onMicTap">
        <image class="ais__input-mic-icon" src="/assets/icons/mic.svg" mode="aspectFit" />
      </view>
      <input
        class="ais__input-field"
        placeholder="说点什么，或长按语音…"
        value="{{text}}"
        bindinput="onInputChange"
        confirm-type="send"
        bindconfirm="onSendTap"
      />
      <view wx:if="{{streaming}}" class="ais__input-stop" bindtap="onAbort">
        <image class="ais__input-send-icon" src="/assets/icons/stop.svg" mode="aspectFit" />
      </view>
      <view wx:else class="ais__input-send" bindtap="onSendTap">
        <image class="ais__input-send-icon" src="/assets/icons/send.svg" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>
