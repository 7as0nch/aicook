.pill {
  display: inline-flex;
  align-items: center;
  background: var(--color-primary-bg);
  border-radius: 9999rpx;
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
  margin: 0;
  line-height: 1.4;
}

.pill--sm {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
}

.pill--selected {
  background: var(--color-primary);
  color: #FFFFFF;
}

.pill--add {
  background: transparent;
  border: 2rpx dashed var(--color-text-secondary);
  color: var(--color-text-secondary);
}

.pill__emoji {
  margin-right: 6rpx;
  font-size: 26rpx;
}

.pill__text {
  font-weight: 400;
}

.pill__close {
  margin-left: 8rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
}
