.mb {
  display: flex;
  align-items: center;
}

.mb--horizontal {
  flex-direction: row;
}

.mb--vertical {
  flex-direction: column;
  text-align: center;
}

.mb__avatar {
  position: relative;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.mb__avatar--sm { width: 48rpx; height: 48rpx; }
.mb__avatar--md { width: 80rpx; height: 80rpx; }
.mb__avatar--lg { width: 120rpx; height: 120rpx; }

.mb__img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.mb__emoji {
  font-size: 40rpx;
  line-height: 1;
}

.mb__avatar--sm .mb__emoji { font-size: 28rpx; }
.mb__avatar--lg .mb__emoji { font-size: 64rpx; }

.mb__bubble {
  background: var(--color-primary-bg);
  color: var(--color-text-primary);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
  line-height: 1.4;
}

.mb--vertical .mb__bubble {
  margin-left: 0;
  margin-top: 12rpx;
}
