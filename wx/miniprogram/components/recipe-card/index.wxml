<!-- hero variant -->
<view wx:if="{{variant === 'hero'}}" class="rc rc--hero" bindtap="onTap">
  <view class="rc-hero__left">
    <view wx:if="{{label}}" class="rc-hero__tag">{{label}}</view>
    <view class="rc-hero__title">{{recipe.title || ''}}</view>
    <view class="rc-hero__meta">
      <text wx:if="{{recipe.category}}">{{recipe.category}}</text>
      <text wx:if="{{recipe.category && recipe.total_minutes}}"> · </text>
      <text wx:if="{{recipe.total_minutes}}">{{recipe.total_minutes}}分钟</text>
      <text wx:if="{{recipe.total_minutes && recipe.servings}}"> · </text>
      <text wx:if="{{recipe.servings}}">{{recipe.servings}}人</text>
    </view>
    <view wx:if="{{matchPercent}}" class="rc-hero__match">
      <text class="rc-hero__match-dot">●</text>
      <text>{{matchPercent}}% 匹配 · 冰箱食材命中高</text>
    </view>
    <view class="rc-hero__cta">{{ctaText}} ></view>
  </view>
  <view class="rc-hero__cover">
    <image wx:if="{{recipe.cover_image_url}}" class="rc-hero__cover-img" src="{{recipe.cover_image_url}}" mode="aspectFill" />
    <view wx:else class="rc-hero__cover-ph">🖼</view>
  </view>
</view>

<!-- grid variant：首页双列 -->
<view wx:elif="{{variant === 'grid'}}" class="rc rc--grid" bindtap="onTap">
  <view class="rc-grid__cover">
    <image wx:if="{{recipe.cover_image_url}}" class="rc-grid__cover-img" src="{{recipe.cover_image_url}}" mode="aspectFill" />
    <view wx:else class="rc-grid__cover-ph">🍳</view>
    <view wx:if="{{showHeart}}" class="rc-grid__heart" catchtap="onHeartTap">
      <text>{{recipe.favored ? '❤️' : '🤍'}}</text>
    </view>
  </view>
  <view class="rc-grid__title">{{recipe.title || ''}}</view>
  <view class="rc-grid__meta">
    <text wx:if="{{recipe.total_minutes}}">{{recipe.total_minutes}}分钟</text>
    <text wx:if="{{recipe.total_minutes && recipe.servings}}"> · </text>
    <text wx:if="{{recipe.servings}}">{{recipe.servings}}人</text>
  </view>
  <view wx:if="{{matchPercent}}" class="rc-grid__match">
    <text class="rc-grid__match-dot">●</text>
    <text>{{matchPercent}}% 匹配</text>
  </view>
</view>

<!-- numbered variant：今日推荐排行 -->
<view wx:elif="{{variant === 'numbered'}}" class="rc rc--numbered" bindtap="onTap">
  <view class="rc-num__rank">{{rank}}</view>
  <view class="rc-num__cover">
    <image wx:if="{{recipe.cover_image_url}}" class="rc-num__cover-img" src="{{recipe.cover_image_url}}" mode="aspectFill" />
    <view wx:else class="rc-num__cover-ph">🍳</view>
  </view>
  <view class="rc-num__body">
    <view class="rc-num__head">
      <view class="rc-num__title">{{recipe.title || ''}}</view>
      <view wx:if="{{matchPercent}}" class="rc-num__match">{{matchPercent}}%匹配</view>
    </view>
    <view class="rc-num__meta">
      <text wx:if="{{recipe.total_minutes}}">{{recipe.total_minutes}}分钟</text>
      <text wx:if="{{recipe.total_minutes && recipe.servings}}"> · </text>
      <text wx:if="{{recipe.servings}}">{{recipe.servings}}人</text>
      <text wx:if="{{recipe.difficulty}}"> · {{recipe.difficulty === 1 ? '简单' : recipe.difficulty === 2 ? '中等' : '困难'}}</text>
    </view>
    <view class="rc-num__tags">
      <view wx:for="{{recipe.scenario_tags}}" wx:key="*this" class="rc-num__tag">{{item}}</view>
    </view>
  </view>
</view>

<!-- row variant：计划页三餐里的菜品 -->
<view wx:elif="{{variant === 'row'}}" class="rc rc--row" bindtap="onTap">
  <view class="rc-row__cover">
    <image wx:if="{{recipe.cover_image_url}}" class="rc-row__cover-img" src="{{recipe.cover_image_url}}" mode="aspectFill" />
    <view wx:else class="rc-row__cover-ph">🍳</view>
  </view>
  <view class="rc-row__body">
    <view class="rc-row__title">{{recipe.title || ''}}</view>
    <view class="rc-row__meta">
      <text wx:if="{{recipe.category}}">{{recipe.category}}</text>
      <text wx:if="{{recipe.category && recipe.total_minutes}}"> · </text>
      <text wx:if="{{recipe.total_minutes}}">{{recipe.total_minutes}}分钟</text>
    </view>
  </view>
  <slot name="right" />
</view>
