/* ============ hero ============ */
.rc--hero {
  display: flex;
  background: var(--gradient-peach);
  border-radius: 28rpx;
  padding: 28rpx;
  margin: 0 0 12rpx 0;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.rc-hero__left {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 16rpx;
}

.rc-hero__tag {
  align-self: flex-start;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  margin-bottom: 12rpx;
}

.rc-hero__title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.rc-hero__meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.rc-hero__match {
  font-size: 24rpx;
  color: var(--color-success);
  margin-bottom: 20rpx;
}

.rc-hero__match-dot {
  margin-right: 6rpx;
}

.rc-hero__cta {
  align-self: flex-start;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  padding: 12rpx 28rpx;
  border-radius: 9999rpx;
}

.rc-hero__cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.rc-hero__cover-img {
  width: 100%;
  height: 100%;
}

.rc-hero__cover-ph {
  font-size: 60rpx;
  opacity: 0.5;
}

/* ============ grid ============ */
.rc--grid {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.rc-grid__cover {
  position: relative;
  width: 100%;
  height: 240rpx;
  border-radius: 24rpx;
  background: var(--gradient-peach);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.rc-grid__cover-img {
  width: 100%;
  height: 100%;
}

.rc-grid__cover-ph {
  font-size: 60rpx;
  opacity: 0.5;
}

.rc-grid__heart {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.rc-grid__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.rc-grid__meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.rc-grid__match {
  font-size: 22rpx;
  color: var(--color-success);
}

.rc-grid__match-dot {
  margin-right: 4rpx;
}

/* ============ numbered ============ */
.rc--numbered {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  position: relative;
}

.rc-num__rank {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.rc-num__cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: var(--gradient-peach);
  margin-right: 20rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rc-num__cover-img { width: 100%; height: 100%; }
.rc-num__cover-ph { font-size: 50rpx; opacity: 0.5; }

.rc-num__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.rc-num__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.rc-num__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
  padding-right: 8rpx;
}

.rc-num__match {
  background: var(--color-success-bg);
  color: var(--color-success);
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
  flex-shrink: 0;
}

.rc-num__meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.rc-num__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.rc-num__tag {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
}

/* ============ row ============ */
.rc--row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 12rpx;
  border-radius: 16rpx;
}

.rc-row__cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: var(--gradient-peach);
  margin-right: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rc-row__cover-img { width: 100%; height: 100%; }
.rc-row__cover-ph { font-size: 32rpx; opacity: 0.5; }

.rc-row__body { flex: 1; }

.rc-row__title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.rc-row__meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
