.sc {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
}

.sc__value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.sc__label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}
