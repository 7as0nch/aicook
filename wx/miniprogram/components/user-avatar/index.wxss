.ua {
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFB366 0%, #FF7A00 100%);
  flex-shrink: 0;
}

.ua__img {
  width: 100%;
  height: 100%;
}

.ua__txt {
  color: #FFFFFF;
  font-size: 0.46em;
  font-weight: 600;
  line-height: 1;
}
