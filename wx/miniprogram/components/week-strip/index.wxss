.ws {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-card);
}

.ws__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ws__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.ws__range {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.ws__row {
  display: flex;
  justify-content: space-between;
}

.ws__day {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  width: 72rpx;
  border-radius: 9999rpx;
}

.ws__day--active {
  background: var(--color-primary);
  color: #FFFFFF;
}

.ws__week {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.2;
}

.ws__day--active .ws__week {
  color: rgba(255,255,255,0.85);
}

.ws__num {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
  margin-top: 4rpx;
}

.ws__day--active .ws__num {
  color: #FFFFFF;
}
