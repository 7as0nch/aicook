.tab-bar--hidden {
  display: none !important;
}

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.tab-row {
  display: flex;
  align-items: center;
  height: 100rpx;
  position: relative;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9B978F;
  height: 100rpx;
  transition: color 0.18s ease;
}

.tab-item.active {
  color: #FF7A00;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.tab-icon-img {
  width: 48rpx;
  height: 48rpx;
  transition: transform 0.18s ease;
}

.tab-item.active .tab-icon-img {
  transform: scale(1.08);
}

.tab-label {
  font-size: 20rpx;
  margin-top: 4rpx;
  transition: font-weight 0.18s ease;
}

.tab-item.active .tab-label {
  font-weight: 600;
}

/* 中间浮按占位（占据 flex 空间） */
.tab-fab-slot {
  flex: 1;
}

/* 凸起浮按 */
.tab-fab {
  position: absolute;
  left: 50%;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB366 0%, #FF7A00 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 0, 0.32);
  z-index: 101;
}

.fab-icon {
  width: 52rpx;
  height: 52rpx;
}

.fab-inner {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-emoji {
  font-size: 56rpx;
  line-height: 1;
}
