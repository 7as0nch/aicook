<view class="chat">
  <custom-navbar showBack="{{false}}">
    <view slot="left" class="chat__back" bindtap="onBack">
      <image class="chat__back-icon" src="/assets/icons/back.svg" mode="aspectFit" />
    </view>
    <view slot="title" class="chat__head-title">
      <view class="chat__head-avatar">
        <image class="chat__head-avatar-img" src="/assets/mascot/bao-default.png" mode="aspectFit" />
      </view>
      <view class="chat__head-text">
        <text class="chat__head-name">厨艺助理 AI</text>
        <view class="chat__head-sub">
          <view class="chat__head-dot"></view>
          <text>在线 · 随时为你出主意</text>
        </view>
      </view>
    </view>
    <view slot="right" class="chat__head-actions">
      <view class="chat__history" bindtap="onOpenHistory">
        <image class="chat__history-icon" src="/assets/icons/clock.png" mode="aspectFit" />
      </view>
      <view class="chat__new" bindtap="onNew">
        <text>+</text>
      </view>
    </view>
  </custom-navbar>

  <scroll-view
    class="chat__body"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <!-- 空态：mascot greeting + 2x2 + 3 suggestion -->
    <view wx:if="{{!messages.length}}" class="chat__empty">
      <view class="chat__greet">
        <view class="chat__greet-mascot">
          <image class="chat__greet-mascot-img" src="/assets/mascot/bao-default.png" mode="aspectFit" />
        </view>
        <view class="chat__greet-bubble">
          你好！我是你的厨艺助理 包包 👋 不知道吃什么？拍张冰箱照，我来帮你出主意～
        </view>
      </view>

      <view class="chat__quick">
        <view
          wx:for="{{quickActions}}"
          wx:key="id"
          class="chat__quick-card"
          data-id="{{item.id}}"
          bindtap="onQuickTap"
        >
          <view class="chat__quick-icon">
            <image class="chat__quick-icon-img" src="{{item.iconSrc}}" mode="aspectFit" />
          </view>
          <view class="chat__quick-text">
            <text class="chat__quick-label">{{item.label}}</text>
            <text class="chat__quick-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="chat__suggest-head">
        <text>✦ 你也可以这样问我</text>
      </view>
      <view class="chat__suggest-list">
        <view
          wx:for="{{suggestions}}"
          wx:key="*this"
          class="chat__suggest-item"
          data-text="{{item}}"
          bindtap="onSuggestionTap"
        >
          <text>{{item}}</text>
          <text class="chat__suggest-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 消息列表（无任何可渲染内容的旧空消息直接隐藏） -->
    <block wx:for="{{messages}}" wx:key="client_id" wx:for-item="msg">
      <view wx:if="{{msg.segments.length || msg.status === 'streaming' || msg.flow_count}}" id="m-{{msg.client_id}}" class="chat__msg chat__msg--{{msg.role}}">
        <view wx:if="{{msg.role === 'assistant'}}" class="chat__avatar">
          <image class="chat__avatar-img" src="/assets/mascot/bao-default.png" mode="aspectFit" />
        </view>
        <view class="chat__col">
          <view class="chat__bubble">
            <block wx:for="{{msg.segments}}" wx:for-item="seg" wx:key="index">
              <block wx:if="{{seg.kind === 'text'}}">
                <rich-text wx:if="{{seg.nodes}}" class="chat__rich" nodes="{{seg.nodes}}" />
                <view wx:else class="chat__text">{{seg.content}}</view>
              </block>
              <view wx:elif="{{seg.kind === 'reasoning'}}" class="chat__reasoning">
                <view class="chat__reasoning-head" data-cid="{{msg.client_id}}" catchtap="onReasonToggle">
                  <view class="chat__reasoning-dot"></view>
                  <text class="chat__reasoning-label">💭 推理过程</text>
                  <text class="chat__reasoning-chevron">{{msg.reasoning_collapsed ? '展开 ▸' : '收起 ▾'}}</text>
                </view>
                <text wx:if="{{!msg.reasoning_collapsed}}" class="chat__reasoning-text">{{seg.content}}</text>
              </view>
              <view wx:elif="{{seg.kind === 'recipe_card'}}" class="chat__recipe" data-id="{{seg.recipe_id}}" data-cid="{{msg.client_id}}" data-idx="{{index}}" bindtap="onRecipeCardTap">
                <view class="chat__recipe-cover chat__recipe-cover--ph">
                  <image wx:if="{{seg.cover_image_url}}" class="chat__recipe-cover-img" src="{{seg.cover_image_url}}" mode="aspectFill" />
                </view>
                <view class="chat__recipe-body">
                  <view class="chat__recipe-title">{{seg.title}}</view>
                  <view class="chat__recipe-summary">{{seg.summary || ''}}</view>
                  <view class="chat__recipe-cta">{{seg.recipe_id ? '查看详情 ›' : '✎ 编辑并保存 ›'}}</view>
                </view>
              </view>
              <view wx:elif="{{seg.kind === 'approval'}}" class="chat__approval">
                <text class="chat__approval-prompt">{{seg.prompt}}</text>
                <view wx:if="{{seg.options.length}}" class="chat__approval-opts">
                  <view
                    wx:for="{{seg.options}}"
                    wx:for-item="opt"
                    wx:key="id"
                    class="chat__approval-opt {{seg.selected_map[opt.id] ? 'chat__approval-opt--on' : ''}} {{seg.answered ? 'chat__approval-opt--done' : ''}}"
                    data-cid="{{msg.client_id}}"
                    data-aid="{{seg.approval_id}}"
                    data-oid="{{opt.id}}"
                    catchtap="onApprovalOptionTap"
                  >
                    <text class="chat__approval-opt-title">{{opt.title}}</text>
                    <text wx:if="{{opt.summary}}" class="chat__approval-opt-sum">{{opt.summary}}</text>
                  </view>
                </view>
                <view wx:if="{{!seg.answered && (seg.selection_mode === 'multi' || seg.allow_skip)}}" class="chat__approval-actions">
                  <view
                    wx:if="{{seg.allow_skip}}"
                    class="chat__approval-skip"
                    data-cid="{{msg.client_id}}"
                    data-aid="{{seg.approval_id}}"
                    catchtap="onApprovalSkip"
                  >跳过</view>
                  <view
                    wx:if="{{seg.selection_mode === 'multi'}}"
                    class="chat__approval-confirm"
                    data-cid="{{msg.client_id}}"
                    data-aid="{{seg.approval_id}}"
                    catchtap="onApprovalConfirm"
                  >确认选择</view>
                </view>
                <view wx:if="{{seg.answered}}" class="chat__approval-answered">✓ 已选择{{seg.selected_label ? '：' + seg.selected_label : ''}}</view>
              </view>
              <view wx:elif="{{seg.kind === 'sources'}}" class="chat__sources">
                <text class="chat__sources-head">🔎 参考来源（{{seg.sources.length}}）</text>
                <scroll-view scroll-x class="chat__sources-scroll">
                  <view class="chat__sources-row">
                    <view
                      wx:for="{{seg.sources}}"
                      wx:for-item="src"
                      wx:key="title"
                      class="chat__source-card"
                    >
                      <text class="chat__source-title">{{src.title}}</text>
                      <text wx:if="{{src.snippet}}" class="chat__source-snippet">{{src.snippet}}</text>
                      <text wx:if="{{src.site_name}}" class="chat__source-site">{{src.site_name}}</text>
                    </view>
                  </view>
                </scroll-view>
              </view>
              <view wx:elif="{{seg.kind === 'error'}}" class="chat__error">⚠ {{seg.message}}</view>
            </block>
            <view wx:if="{{msg.status === 'streaming' && !msg.segments.length}}" class="chat__typing">
              <text>包包正在思考</text>
              <text class="chat__typing-dots">...</text>
            </view>
          </view>
          <!-- 工作流时间线（tool_call / agent / status）：默认折叠，头部计数 + 流式中实时行 -->
          <view wx:if="{{msg.role === 'assistant' && msg.flow_count}}" class="chat__flowline">
            <view class="chat__flow-head" data-cid="{{msg.client_id}}" catchtap="onFlowToggle">
              <text class="chat__flow-head-icon">⚙️</text>
              <text class="chat__flow-head-text">执行过程 · {{msg.flow_count}} 步</text>
              <text class="chat__flow-head-chevron">{{msg.flow_collapsed ? '展开 ▸' : '收起 ▾'}}</text>
            </view>
            <view wx:if="{{msg.flow_collapsed && msg.status === 'streaming' && msg.flow_live}}" class="chat__flow">
              <view class="chat__flow-dot chat__flow-dot--running"></view>
              <text>{{msg.flow_live}}</text>
            </view>
            <block wx:if="{{!msg.flow_collapsed}}">
              <block wx:for="{{msg.segments}}" wx:for-item="seg" wx:key="index">
                <view wx:if="{{seg.kind === 'tool_call'}}" class="chat__flow">
                  <view class="chat__flow-dot {{seg.status === 'running' ? 'chat__flow-dot--running' : ''}}"></view>
                  <text>调用 {{seg.tool_name}}</text>
                </view>
                <view wx:elif="{{seg.kind === 'agent'}}" class="chat__flow">
                  <view class="chat__flow-dot chat__flow-dot--agent {{seg.status === 'running' ? 'chat__flow-dot--running' : ''}}"></view>
                  <text>{{seg.content}}</text>
                </view>
                <view wx:elif="{{seg.kind === 'status'}}" class="chat__flow">
                  <view class="chat__flow-dot chat__flow-dot--status {{seg.status === 'running' ? 'chat__flow-dot--running' : ''}}"></view>
                  <text>{{seg.message}}</text>
                </view>
              </block>
            </block>
          </view>
        </view>
      </view>
    </block>

    <view class="chat__bottom-spacer"></view>
  </scroll-view>

  <view class="chat__modes">
    <mode-chip dotColor="#FF7A00" label="深度思考" active="{{reasoningEnabled}}" bind:toggle="onToggleReasoning" />
    <mode-chip dotColor="#2DBE7A" label="联网搜索" active="{{webSearchEnabled}}" bind:toggle="onToggleWebSearch" />
    <mode-chip dotColor="#9B978F" label="图文识别" active="{{imageRecipeEnabled}}" bind:toggle="onToggleImageRecipe" />
  </view>

  <view class="chat__input">
    <view class="chat__input-mic {{recording ? 'chat__input-mic--rec' : ''}}" bindtap="onMicTap">
      <image class="chat__input-mic-icon" src="/assets/icons/mic.svg" mode="aspectFit" />
    </view>
    <text wx:if="{{recording}}" class="chat__input-rec-tip">录音中 {{recordSeconds}}s · 点麦克风结束</text>
    <input
      wx:else
      class="chat__input-field"
      placeholder="说点什么，或点麦克风语音输入…"
      value="{{text}}"
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="onSendTap"
    />
    <view wx:if="{{streaming}}" class="chat__input-stop" bindtap="onAbort">
      <image class="chat__input-send-icon" src="/assets/icons/stop.svg" mode="aspectFit" />
    </view>
    <view wx:else class="chat__input-send" bindtap="onSendTap">
      <image class="chat__input-send-icon" src="/assets/icons/send.svg" mode="aspectFit" />
    </view>
  </view>
</view>
