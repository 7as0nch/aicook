.chat {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FAFAF8;
}

/* ========== Header ========== */
.chat__head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #FFFFFF;
  border-bottom: 2rpx solid #EFEDE8;
  flex-shrink: 0;
}

.chat__back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #1F1B16;
  flex-shrink: 0;
}

.chat__back-arrow {
  line-height: 0.8;
  margin-top: -4rpx;
}

.chat__head-title {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.chat__head-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat__head-avatar-img {
  width: 56rpx;
  height: 56rpx;
}

.chat__head-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.chat__head-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
  line-height: 1.1;
}

.chat__head-sub {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #9B978F;
}

.chat__head-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2DBE7A;
}

.chat__history {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F4F5F7;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.chat__history-icon { width: 36rpx; height: 36rpx; }

.chat__new {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #EF6E00;
  font-weight: 300;
  flex-shrink: 0;
}

/* ========== Body ========== */
.chat__body {
  flex: 1;
  min-height: 0;
  padding: 24rpx 32rpx 0;
}

/* ========== 空态 ========== */
.chat__empty {
  padding: 8rpx 0;
}

.chat__greet {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.chat__greet-mascot {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat__greet-mascot-img {
  width: 72rpx;
  height: 72rpx;
}

.chat__greet-bubble {
  flex: 1;
  background: #FFF6EE;
  padding: 22rpx 26rpx;
  border-radius: 28rpx;
  border-top-left-radius: 8rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: #1F1B16;
}

.chat__quick {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 32rpx;
}

.chat__quick-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 24rpx;
  padding: 22rpx;
}

.chat__quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat__quick-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.chat__quick-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.chat__quick-label {
  font-size: 27rpx;
  font-weight: 600;
  color: #1F1B16;
}

.chat__quick-desc {
  font-size: 22rpx;
  color: #9B978F;
}

.chat__suggest-head {
  display: flex;
  align-items: center;
  font-size: 25rpx;
  color: #FF7A00;
  margin-bottom: 16rpx;
}

.chat__suggest-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chat__suggest-item {
  background: #FFF6EE;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #1F1B16;
}

.chat__suggest-arrow {
  color: #9B978F;
  font-size: 30rpx;
}

/* ========== 消息 ========== */
.chat__msg {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.chat__msg--user {
  flex-direction: row-reverse;
}

.chat__avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat__avatar-img {
  width: 52rpx;
  height: 52rpx;
}

.chat__bubble {
  max-width: 76%;
  background: #FFF6EE;
  border-radius: 24rpx;
  border-top-left-radius: 8rpx;
  padding: 22rpx 26rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1F1B16;
  word-break: break-word;
}

.chat__msg--user .chat__bubble {
  background: #FF7A00;
  color: #FFFFFF;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 8rpx;
}

.chat__text {
  white-space: pre-wrap;
}

.chat__reasoning {
  background: rgba(31, 27, 22, 0.05);
  border-radius: 16rpx;
  padding: 14rpx 18rpx;
  font-size: 24rpx;
  color: #5C544A;
  margin-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.chat__reasoning-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.chat__reasoning-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #7A5AF8;
}

.chat__reasoning-label {
  font-weight: 500;
  color: #1F1B16;
}

.chat__tool {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #9B978F;
  background: #F4F5F7;
  padding: 10rpx 18rpx;
  border-radius: 9999rpx;
  margin-bottom: 8rpx;
  align-self: flex-start;
}

.chat__tool-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2DBE7A;
  animation: chat-blink 1.2s infinite;
}

.chat__agent {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #FF7A00;
  background: #FFF6EE;
  padding: 10rpx 18rpx;
  border-radius: 9999rpx;
  margin-bottom: 8rpx;
  align-self: flex-start;
}

.chat__agent-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #FF7A00;
  animation: chat-blink 1.2s infinite;
}

@keyframes chat-blink {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.chat__approval {
  background: #FFF7E6;
  border: 1rpx solid #F5C97E;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1F1B16;
  margin-top: 8rpx;
}

.chat__sources {
  margin-top: 16rpx;
}

/* 可点折叠头部：默认折叠（仿工具时间线），避免联网搜索结果铺满屏 */
.chat__sources-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 16rpx;
  background: #F4F2EE;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}
.chat__sources-head-text { font-size: 22rpx; color: #6B6660; }
.chat__sources-chevron { font-size: 21rpx; color: #9B978F; }

.chat__sources-scroll {
  white-space: nowrap;
}

.chat__sources-row {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.chat__source-card {
  flex-shrink: 0;
  width: 240rpx;
  padding: 14rpx 16rpx;
  background: #FFFFFF;
  border: 1rpx solid #F4F2EE;
  border-radius: 16rpx;
  display: inline-flex;
  flex-direction: column;
  gap: 6rpx;
}

.chat__source-title {
  font-size: 22rpx;
  color: #1F1B16;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat__source-snippet {
  font-size: 20rpx;
  color: #9B978F;
  line-height: 1.4;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  white-space: normal;
}

.chat__recipe-cta {
  font-size: 22rpx;
  color: #FF7A00;
  font-weight: 500;
  margin-top: 4rpx;
}

.chat__recipe {
  display: flex;
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 14rpx;
  margin-top: 10rpx;
  gap: 16rpx;
}

.chat__recipe-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #FFEAD2 0%, #FFD6AA 100%);
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat__recipe-cover-img { width: 100%; height: 100%; }

.chat__recipe-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}

.chat__recipe-title {
  font-weight: 600;
  font-size: 27rpx;
  color: #1F1B16;
}

.chat__recipe-summary {
  font-size: 23rpx;
  color: #9B978F;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.chat__status {
  font-size: 22rpx;
  color: #9B978F;
  font-style: italic;
}

.chat__error {
  color: #E5604A;
  font-size: 24rpx;
}

.chat__typing {
  color: #9B978F;
  font-size: 24rpx;
}

.chat__typing-dots {
  animation: dots 1s steps(4, end) infinite;
}

@keyframes dots {
  0%, 20% { opacity: 0; }
  100% { opacity: 1; }
}

.chat__bottom-spacer { height: 40rpx; }

/* ========== Mode chips ========== */
.chat__modes {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  border-top: 2rpx solid #EFEDE8;
  flex-shrink: 0;
}

/* ========== 输入栏 ========== */
.chat__input {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  gap: 12rpx;
  flex-shrink: 0;
}

.chat__input-mic,
.chat__input-send,
.chat__input-stop {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat__input-mic {
  background: #FFF6EE;
}

.chat__input-mic--rec {
  background: rgba(229, 96, 74, 0.18);
}

/* 录音中替换输入框的提示条 */
.chat__input-rec-tip {
  flex: 1;
  background: rgba(229, 96, 74, 0.10);
  border-radius: 9999rpx;
  padding: 0 28rpx;
  font-size: 27rpx;
  height: 72rpx;
  line-height: 72rpx;
  color: #E5604A;
}

.chat__input-mic-icon {
  width: 36rpx;
  height: 36rpx;
}

.chat__input-field {
  flex: 1;
  background: #F4F5F7;
  border-radius: 9999rpx;
  padding: 0 28rpx;
  font-size: 27rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.chat__input-send {
  background: #FF7A00;
}

.chat__input-send-icon {
  width: 36rpx;
  height: 36rpx;
}

/* 生成中：停止按钮（品牌红 + 圆角方块图标） */
.chat__input-stop {
  background: #E5604A;
}

/* ===== 工作流时间线改造（V11）：气泡 + 下方 flow 列 ===== */
.chat__col {
  max-width: 84%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.chat__msg--user .chat__col {
  align-items: flex-end;
}

/* 气泡宽度交给外层 col 控制 */
.chat__bubble {
  max-width: 100%;
}

.chat__rich {
  display: block;
  word-break: break-all;
}

.chat__flowline {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-left: 8rpx;
}

.chat__flowline:empty { display: none; }

.chat__flow {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #9B978F;
  background: #F4F5F7;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  align-self: flex-start;
  max-width: 100%;
}

.chat__flow text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 折叠头部：计数 + 展开/收起 */
.chat__flow-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #9B978F;
  background: #F4F5F7;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  align-self: flex-start;
}

.chat__flow-head-icon { font-size: 22rpx; }
.chat__flow-head-chevron { color: #B8B4AC; }

/* 完成态静态色点；仅 running 闪烁 */
.chat__flow-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2DBE7A;
  flex-shrink: 0;
}

.chat__flow-dot--agent { background: #FF7A00; }
.chat__flow-dot--status { background: #9B978F; }
.chat__flow-dot--running { animation: chat-blink 1.2s infinite; }

/* 思考折叠 */
.chat__reasoning-chevron {
  margin-left: auto;
  font-size: 21rpx;
  color: #9B8FD8;
}

/* human-in-loop 选项 */
.chat__approval {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.chat__approval-prompt { font-weight: 500; line-height: 1.5; }

.chat__approval-opts {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.chat__approval-opt {
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.chat__approval-opt--on {
  border-color: #FF7A00;
  background: #FFF6EE;
}

.chat__approval-opt--done { opacity: 0.65; }

.chat__approval-opt-title { font-size: 26rpx; color: #1F1B16; font-weight: 500; }
.chat__approval-opt-sum { font-size: 22rpx; color: #9B978F; line-height: 1.4; }

.chat__approval-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.chat__approval-skip {
  padding: 10rpx 26rpx;
  border-radius: 26rpx;
  background: #F4F5F7;
  color: #6E6A62;
  font-size: 23rpx;
}

.chat__approval-confirm {
  padding: 10rpx 30rpx;
  border-radius: 26rpx;
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 23rpx;
  font-weight: 500;
}

.chat__approval-answered { font-size: 22rpx; color: #2DBE7A; }

.chat__source-site { font-size: 20rpx; color: #B8B4AC; display: block; margin-top: 4rpx; }
