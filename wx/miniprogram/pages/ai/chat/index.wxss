.placeholder-page { min-height: 100vh; padding: var(--spacing-md); text-align: center; padding-top: 240rpx; }
.placeholder-page .emoji { font-size: 120rpx; }
.placeholder-page .title { font-size: var(--font-lg); margin-top: var(--spacing-md); }
.placeholder-page .desc { color: var(--color-text-secondary); font-size: var(--font-sm); margin-top: var(--spacing-sm); }
