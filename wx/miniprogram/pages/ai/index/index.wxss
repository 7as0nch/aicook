.ai-page {
  min-height: 100vh;
  padding: var(--spacing-md);
}
.placeholder {
  margin-top: 240rpx;
  text-align: center;
}
.placeholder .emoji { font-size: 120rpx; }
.placeholder .title { font-size: var(--font-lg); margin-top: var(--spacing-md); }
.placeholder .desc { margin-top: var(--spacing-sm); color: var(--color-text-secondary); font-size: var(--font-sm); }
.primary-btn {
  margin-top: var(--spacing-lg);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-pill);
  padding: 20rpx 80rpx;
  font-size: var(--font-md);
  display: inline-block;
}
