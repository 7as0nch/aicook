.home {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 0 48rpx 220rpx;
}

/* ========== 顶部 ========== */
.home__top {
  padding-top: 24rpx;
  margin-bottom: 36rpx;
}

.home__top-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.home__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx solid #FFE4CC;
  flex-shrink: 0;
}

.home__avatar-img { width: 100%; height: 100%; }

.home__avatar-fallback { width: 44rpx; height: 44rpx; opacity: 0.7; }

/* 搜索栏 */
.home__search {
  flex: 1;
  display: flex;
  align-items: center;
  height: 88rpx;
  background: #F4F5F7;
  border-radius: 44rpx;
  padding: 0 28rpx;
  min-width: 0;
}

.home__search-ic {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.home__search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1F1B16;
  min-width: 0;
}

.home__search-ph {
  color: #9B978F;
}

.home__search-div {
  width: 2rpx;
  height: 44rpx;
  background: #EFEDE8;
  margin: 0 16rpx;
}

.home__search-scan {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

/* ========== Hero 卡 ========== */
.home__hero {
  position: relative;
  background: #FFF6EE;
  border-radius: 40rpx;
  overflow: hidden;
  height: 288rpx;
  display: flex;
  margin-bottom: 40rpx;
}

.home__hero-stripe {
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  width: 12rpx;
  background: #FF7A00;
}

.home__hero-body {
  flex: 1;
  padding: 36rpx 0 36rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.home__hero-tag {
  align-self: flex-start;
  background: #FFE4C9;
  color: #EF6E00;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  line-height: 1.2;
}

.home__hero-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #1F1B16;
  line-height: 1.2;
  margin-bottom: 14rpx;
}

.home__hero-meta {
  font-size: 24rpx;
  color: #9B978F;
  margin-bottom: 16rpx;
}

.home__hero-match {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #2DBE7A;
  margin-bottom: 20rpx;
}

.home__hero-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2DBE7A;
  margin-right: 10rpx;
}

.home__hero-cta {
  align-self: flex-start;
  display: flex;
  align-items: center;
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 500;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  line-height: 1.2;
}

.home__hero-cta-arrow {
  width: 22rpx;
  height: 22rpx;
  margin-left: 8rpx;
}

.home__hero-cover {
  width: 198rpx;
  height: 228rpx;
  margin: 30rpx 30rpx 30rpx 0;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #FFEAD2 0%, #FFD6AA 100%);
  overflow: hidden;
  flex-shrink: 0;
}

.home__hero-cover-img { width: 100%; height: 100%; }

/* ========== Section head ========== */
.home__sec-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 12rpx 0 24rpx;
}

.home__sec-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
}

.home__sec-sub {
  font-size: 24rpx;
  color: #9B978F;
}

/* ========== 快捷入口 ========== */
.home__quick {
  display: flex;
  justify-content: space-between;
  padding: 0 14rpx;
  margin-bottom: 40rpx;
}

.home__qe {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 130rpx;
}

.home__qe-circle {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.home__qe-circle--orange {
  background: #FFEDD9;
}

.home__qe-circle--green {
  background: #D7F2E4;
}

.home__qe-icon {
  width: 52rpx;
  height: 52rpx;
}

/* 图标保持原色（深灰），在彩色背景上清晰可读；不再使用 CSS filter 染色 */

.home__qe-label {
  font-size: 23rpx;
  color: #6E6A62;
}

/* ========== 灵感推荐 ========== */
.home__chips {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.home__chips-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.home__chip {
  padding: 12rpx 28rpx;
  background: #F4F5F7;
  color: #6E6A62;
  border-radius: 32rpx;
  font-size: 26rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.home__chip--active {
  background: #FF7A00;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 按类型浏览 ========== */
.home__cats {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.home__cats-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.home__cat {
  padding: 16rpx 34rpx;
  background: #FFF6EE;
  color: #FF7A00;
  border-radius: 9999rpx;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.2;
  flex-shrink: 0;
}

/* ========== 双列网格 ========== */
.home__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.home__card {
  width: calc(50% - 12rpx);
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.home__card-cover {
  position: relative;
  width: 100%;
  height: 208rpx;
  background: linear-gradient(180deg, #FFEAD2 0%, #FFD6AA 100%);
  overflow: hidden;
}

.home__card-img {
  width: 100%;
  height: 100%;
}

.home__card-heart {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(31, 27, 22, 0.12);
}

/* 已收藏：橙底，与详情页“已收藏”态一致 */
.home__card-heart--on {
  background: #FFEAD9;
}

.home__card-heart-icon {
  width: 30rpx;
  height: 30rpx;
}

.home__card-title {
  font-size: 29rpx;
  font-weight: 600;
  color: #1F1B16;
  margin: 18rpx 22rpx 0;
}

.home__card-meta {
  font-size: 23rpx;
  color: #9B978F;
  margin: 6rpx 22rpx 0;
}

.home__card-match {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #2DBE7A;
  margin: 8rpx 22rpx 22rpx;
}

.home__card-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2DBE7A;
  margin-right: 8rpx;
}

.home__empty {
  text-align: center;
  color: #9B978F;
  padding: 40rpx 0;
  font-size: 26rpx;
}

.home__spacer { height: 80rpx; }
