.hist {
  min-height: 100vh;
  background: #FAFAF8;
  padding-bottom: 80rpx;
}

.hist__navbar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  padding-top: env(safe-area-inset-top);
  box-sizing: content-box;
  background: #FFFFFF;
  border-bottom: 2rpx solid #EFEDE8;
  gap: 16rpx;
}

.hist__nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hist__nav-icon {
  width: 40rpx;
  height: 40rpx;
}

.hist__nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-right: 72rpx;
}

.hist__nav-placeholder {
  width: 72rpx;
  height: 72rpx;
}

/* 连续打卡 */
.hist__streak-card {
  margin: 32rpx 48rpx 0;
  background: linear-gradient(135deg, #FFD8AB 0%, #FFAE5C 100%);
  border-radius: 40rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 16rpx 32rpx rgba(255, 122, 0, 0.18);
}

.hist__streak-flame {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: #FFF6EE;
}

.hist__streak-flame-icon {
  width: 56rpx;
  height: 56rpx;
}

.hist__streak-body {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.hist__streak-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.hist__streak-unit {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.hist__streak-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 12rpx;
}

.hist__streak-meta {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  align-items: flex-end;
  color: #FFFFFF;
  font-size: 22rpx;
}

.hist__streak-tip {
  font-size: 20rpx;
  opacity: 0.92;
}

/* 分组标题 */
.hist__group-title {
  margin: 32rpx 48rpx 16rpx;
  font-size: 27rpx;
  font-weight: 600;
  color: #1F1B16;
}

.hist__group-card {
  margin: 0 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.hist__item {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 0;
  align-items: flex-start;
}

.hist__item-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #FFEAD2 0%, #FFD6AA 100%);
  flex-shrink: 0;
  overflow: hidden;
}

.hist__item-cover-img { width: 100%; height: 100%; }

.hist__item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.hist__item-name {
  font-size: 29rpx;
  font-weight: 600;
  color: #1F1B16;
}

.hist__item-meta {
  font-size: 23rpx;
  color: #9B978F;
}

.hist__item-stars {
  font-size: 25rpx;
  color: #FFA436;
  letter-spacing: 2rpx;
}

.hist__item-note {
  font-size: 23rpx;
  color: #6E6A62;
  background: #FFF6EE;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-top: 4rpx;
  align-self: flex-start;
}

.hist__divider {
  height: 2rpx;
  background: #F4F2EE;
  margin-left: 138rpx;
}

.hist__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.hist__empty-icon { width: 96rpx; height: 96rpx; opacity: 0.6; }
.hist__empty-text { color: #1F1B16; font-size: 28rpx; font-weight: 500; }
.hist__empty-sub { color: #9B978F; font-size: 24rpx; }

.hist__loading,
.hist__end {
  text-align: center;
  color: #9B978F;
  font-size: 23rpx;
  padding: 32rpx 0;
}

.hist__spacer { height: 60rpx; }
