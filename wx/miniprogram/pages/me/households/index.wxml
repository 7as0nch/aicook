<view class="hh">
  <custom-navbar title="厨房管理">
    <view slot="right" class="hh__nav-btn hh__nav-btn--primary" bindtap="onCreate">
      <text>+</text>
    </view>
  </custom-navbar>

  <!-- 当前厨房卡 -->
  <view class="hh__active">
    <view class="hh__active-stripe"></view>
    <view class="hh__active-head">
      <view class="hh__active-icon">
        <image class="hh__active-icon-img" src="/assets/icons/pot.png" mode="aspectFit" />
      </view>
      <view class="hh__active-titles">
        <view class="hh__active-name-row">
          <text class="hh__active-name">{{current.name || '我的厨房'}}</text>
          <view class="hh__active-badge">使用中</view>
        </view>
        <text class="hh__active-meta">你 · 管理员 · 创建于 {{current.created_label || '本月'}}</text>
      </view>
    </view>
    <view class="hh__avatars">
      <view wx:for="{{members}}" wx:key="id" wx:if="{{index < 4}}" class="hh__avatar">
        <text>{{item.emoji}}</text>
      </view>
      <text class="hh__avatars-text">{{memberPreview}}</text>
    </view>
    <view class="hh__active-divider"></view>
    <view class="hh__share-btn" bindtap="onShareTap">
      <image class="hh__share-icon" src="/assets/icons/share.svg" mode="aspectFit" />
      <text>分享厨房配置</text>
    </view>
  </view>

  <!-- 切换其它厨房 -->
  <view class="hh__section-title">切换其它厨房</view>
  <view class="hh__switch-card">
    <view wx:for="{{others}}" wx:key="id" wx:for-item="o" class="hh__switch-row" data-id="{{o.id}}" bindtap="onSwitchTap">
      <view class="hh__switch-icon">{{o.emoji}}</view>
      <view class="hh__switch-body">
        <text class="hh__switch-name">{{o.name}}</text>
        <text class="hh__switch-meta">{{o.memberLabel}}</text>
      </view>
      <view class="hh__switch-radio"></view>
    </view>
    <view wx:if="{{others.length}}" class="hh__switch-divider"></view>
    <view class="hh__join-row" bindtap="onJoin">
      <text class="hh__join-plus">+</text>
      <text>新建 / 加入厨房</text>
    </view>
  </view>

  <!-- 厨房成员 -->
  <view class="hh__section-row">
    <text class="hh__section-title hh__section-title--inline">厨房成员</text>
    <text class="hh__section-count">共 {{memberCount}} 人</text>
  </view>
  <view class="hh__members-card">
    <block wx:for="{{members}}" wx:key="id">
      <view wx:if="{{index > 0}}" class="hh__members-divider"></view>
      <view class="hh__member-row">
        <view class="hh__member-avatar">{{item.emoji}}</view>
        <text class="hh__member-name">{{item.name}}</text>
        <view class="hh__member-role {{item.isOwner ? 'hh__member-role--admin' : ''}}">{{item.role}}</view>
        <view class="hh__member-more">⋯</view>
      </view>
    </block>
    <view wx:if="{{!members.length}}" class="hh__empty">暂无成员</view>
  </view>

  <view class="hh__spacer"></view>
</view>
