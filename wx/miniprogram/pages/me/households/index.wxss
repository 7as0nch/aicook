.hh {
  min-height: 100vh;
  background: #FAFAF8;
  padding-bottom: 80rpx;
}

/* ========== Navbar ========== */
.hh__navbar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  padding-top: env(safe-area-inset-top);
  box-sizing: content-box;
  background: #FFFFFF;
  border-bottom: 2rpx solid #EFEDE8;
  gap: 16rpx;
}

.hh__nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hh__nav-btn--primary {
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 300;
}

.hh__nav-icon {
  width: 40rpx;
  height: 40rpx;
}

.hh__nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-right: 72rpx; /* 对齐补偿 */
}

.hh__navbar .hh__nav-btn:last-child {
  margin-right: 0;
}

/* ========== 当前厨房卡 ========== */
.hh__active {
  position: relative;
  margin: 32rpx 48rpx 0;
  background: #FFF6EE;
  border: 3rpx solid #FFD9AE;
  border-radius: 40rpx;
  padding: 28rpx;
  overflow: hidden;
}

.hh__active-stripe {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 6rpx;
  background: #FF7A00;
}

.hh__active-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.hh__active-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 32rpx;
  background: #FF7A00;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hh__active-icon-img {
  width: 48rpx;
  height: 48rpx;
  filter: brightness(0) invert(1);
}

.hh__active-titles {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hh__active-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hh__active-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
}

.hh__active-badge {
  background: #2DBE7A;
  color: #FFFFFF;
  font-size: 21rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.hh__active-meta {
  font-size: 24rpx;
  color: #9B978F;
}

.hh__avatars {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.hh__avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFEDD9;
  border: 4rpx solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: -12rpx;
}

.hh__avatar:first-child {
  margin-left: 0;
}

.hh__avatars-text {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #9B978F;
}

.hh__active-divider {
  height: 2rpx;
  background: #F3E3CC;
  margin-bottom: 22rpx;
}

.hh__share-btn {
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 24rpx rgba(255, 122, 0, 0.32);
}

.hh__share-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

/* ========== Section ========== */
.hh__section-title {
  font-size: 27rpx;
  font-weight: 600;
  color: #1F1B16;
  margin: 32rpx 48rpx 16rpx;
}

.hh__section-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 32rpx 48rpx 16rpx;
}

.hh__section-title--inline {
  margin: 0;
}

.hh__section-count {
  font-size: 23rpx;
  color: #9B978F;
}

/* ========== 切换其它厨房 ========== */
.hh__switch-card {
  margin: 0 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.hh__switch-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
}

.hh__switch-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: #F4F5F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  flex-shrink: 0;
}

.hh__switch-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.hh__switch-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F1B16;
}

.hh__switch-meta {
  font-size: 23rpx;
  color: #9B978F;
}

.hh__switch-radio {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #EFEDE8;
  flex-shrink: 0;
}

.hh__switch-divider {
  height: 2rpx;
  background: #EFEDE8;
  margin: 4rpx 0;
}

.hh__join-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
  color: #EF6E00;
  font-size: 26rpx;
  font-weight: 500;
}

.hh__join-plus {
  font-size: 32rpx;
  line-height: 1;
}

/* ========== 厨房成员 ========== */
.hh__members-card {
  margin: 0 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.hh__member-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
}

.hh__member-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  flex-shrink: 0;
}

.hh__member-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #1F1B16;
}

.hh__member-role {
  background: #F4F5F7;
  color: #9B978F;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 18rpx;
  border-radius: 22rpx;
}

.hh__member-role--admin {
  background: #FFF6EE;
  color: #EF6E00;
}

.hh__member-more {
  font-size: 36rpx;
  color: #9B978F;
  margin-left: 12rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.hh__members-divider {
  height: 2rpx;
  background: #F4F2EE;
  margin-left: 92rpx;
}

.hh__empty {
  text-align: center;
  color: #9B978F;
  padding: 60rpx 0;
  font-size: 26rpx;
}

.hh__spacer { height: 60rpx; }
