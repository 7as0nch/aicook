<view class="me">
  <!-- 用户卡 -->
  <view class="me__card me__user-card">
    <view class="me__user-row">
      <view class="me__avatar" bindtap="onAvatarTap">
        <user-avatar url="{{user.avatar_url}}" name="{{user.display_name || user.username}}" size="104rpx" />
      </view>
      <view class="me__user-body">
        <view class="me__user-name">{{user && user.display_name ? user.display_name : '点击登录'}}</view>
        <view wx:if="{{user && user.username}}" class="me__user-id" bindtap="onCopyId">
          <text>ID  {{user.username}}</text>
          <text class="me__user-id-copy">⎘</text>
        </view>
        <view wx:else class="me__user-id">未登录</view>
      </view>
      <view wx:if="{{user}}" class="me__user-edit" bindtap="onAvatarTap">编辑资料</view>
    </view>
    <view class="me__user-divider"></view>
    <view class="me__stats">
      <view class="me__stat" catchtap="onStatFavTap">
        <view wx:if="{{statsLoading}}" class="me__stat-skeleton"></view>
        <view wx:else class="me__stat-num">{{favoritesCount}}</view>
        <view class="me__stat-label">收藏菜谱</view>
      </view>
      <view class="me__stat-div"></view>
      <view class="me__stat" catchtap="onStatMineTap">
        <view wx:if="{{statsLoading}}" class="me__stat-skeleton"></view>
        <view wx:else class="me__stat-num">{{myRecipesCount}}</view>
        <view class="me__stat-label">我的菜谱</view>
      </view>
      <view class="me__stat-div"></view>
      <view class="me__stat" catchtap="onStatStreakTap">
        <view wx:if="{{statsLoading}}" class="me__stat-skeleton"></view>
        <view wx:else class="me__stat-num">{{streakDays}}</view>
        <view class="me__stat-label">连续打卡</view>
      </view>
    </view>
  </view>

  <!-- 我的厨房 -->
  <view class="me__card me__kitchen-card" bindtap="onHouseholdTap">
    <view class="me__kitchen-icon-wrap">
      <image class="me__kitchen-icon" src="/assets/icons/pot.png" mode="aspectFit" />
    </view>
    <view class="me__kitchen-body">
      <view class="me__kitchen-name">{{currentHousehold && currentHousehold.name ? currentHousehold.name : '我的厨房'}}</view>
      <view class="me__kitchen-sub">{{members.length || 1}} 位成员 · 你是管理员</view>
    </view>
    <view class="me__kitchen-cta">
      <text>管理</text>
      <image class="me__kitchen-arrow" src="/assets/icons/right.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- 烹饪历史（按用户要求，上移到设置卡之前） -->
  <view class="me__card me__row-card" data-url="/pages/me/history/index/index" bindtap="onMenuTap">
    <image class="me__row-icon" src="/assets/icons/clock.png" mode="aspectFit" />
    <view class="me__row-text">烹饪历史</view>
    <image class="me__row-arrow" src="/assets/icons/right.svg" mode="aspectFit" />
  </view>

  <!-- 设置卡 -->
  <view class="me__card me__settings-card">
    <view class="me__set-row" data-url="" bindtap="onMenuTap">
      <image class="me__set-icon" src="/assets/icons/bell.png" mode="aspectFit" />
      <view class="me__set-text">消息通知</view>
      <view class="me__set-tag">即将上线</view>
      <image class="me__set-arrow" src="/assets/icons/right.svg" mode="aspectFit" />
    </view>
    <view class="me__set-divider"></view>
    <view class="me__set-row" data-url="" bindtap="onMenuTap">
      <image class="me__set-icon" src="/assets/icons/info.png" mode="aspectFit" />
      <view class="me__set-text">关于 aicook</view>
      <image class="me__set-arrow" src="/assets/icons/right.svg" mode="aspectFit" />
    </view>
    <view class="me__set-divider"></view>
    <view class="me__set-row" data-url="" bindtap="onMenuTap">
      <image class="me__set-icon" src="/assets/icons/shield.png" mode="aspectFit" />
      <view class="me__set-text">用户隐私政策</view>
      <image class="me__set-arrow" src="/assets/icons/right.svg" mode="aspectFit" />
    </view>
    <view class="me__set-divider"></view>
    <view class="me__set-row" data-url="" bindtap="onMenuTap">
      <image class="me__set-icon" src="/assets/icons/help.png" mode="aspectFit" />
      <view class="me__set-text">帮助与反馈</view>
      <image class="me__set-arrow" src="/assets/icons/right.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="me__logout" bindtap="onLogoutTap">
    <image class="me__logout-icon" src="/assets/icons/logout.png" mode="aspectFit" />
    <text>退出登录</text>
  </view>

  <view class="me__spacer"></view>
</view>

<ai-fab />
<ai-sheet context="我的" />
