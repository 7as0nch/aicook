.me {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF1E2 0%, #FAFAF8 320rpx);
  padding: 16rpx 32rpx 220rpx;
}

/* ========== 通用卡片 ========== */
.me__card {
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 28rpx rgba(31, 20, 8, 0.05);
  margin-bottom: 24rpx;
}

/* ========== 用户卡 ========== */
.me__user-card {
  padding: 30rpx 30rpx 24rpx;
}

.me__user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.me__avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #FFEEDC;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.me__avatar-img { width: 100%; height: 100%; }

.me__avatar-default {
  width: 56rpx;
  height: 56rpx;
  opacity: 0.6;
}

.me__user-body {
  flex: 1;
  min-width: 0;
}

.me__user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.me__user-id {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #9B978F;
  margin-top: 8rpx;
  line-height: 1.2;
}

.me__user-id-copy {
  font-size: 22rpx;
  color: #9B978F;
  opacity: 0.7;
}

.me__user-edit {
  background: #FFFFFF;
  border: 2rpx solid #F4D7B3;
  border-radius: 28rpx;
  padding: 10rpx 22rpx;
  font-size: 23rpx;
  font-weight: 500;
  color: #EF6E00;
  line-height: 1.2;
  flex-shrink: 0;
}

.me__user-divider {
  height: 2rpx;
  background: #F4F2EE;
  transform: scaleY(0.5);
  margin: 0 -10rpx 18rpx;
}

.me__stats {
  display: flex;
  align-items: center;
}

.me__stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.me__stat-num {
  font-size: 38rpx;
  font-weight: 700;
  color: #1F1B16;
  line-height: 1.1;
}

.me__stat-label {
  font-size: 22rpx;
  color: #9B978F;
  margin-top: 6rpx;
}

.me__stat-div {
  width: 1rpx;
  height: 48rpx;
  background: #EFEDE8;
  transform: scaleX(0.5);
}

/* ========== 我的厨房 ========== */
.me__kitchen-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 26rpx;
}

.me__kitchen-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF1E2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.me__kitchen-icon {
  width: 40rpx;
  height: 40rpx;
}

.me__kitchen-body {
  flex: 1;
  min-width: 0;
}

.me__kitchen-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
  line-height: 1.2;
}

.me__kitchen-sub {
  font-size: 22rpx;
  color: #9B978F;
  margin-top: 6rpx;
}

.me__kitchen-cta {
  display: flex;
  align-items: center;
  background: #FFF1E2;
  color: #EF6E00;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 18rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.me__kitchen-arrow {
  width: 20rpx;
  height: 20rpx;
  margin-left: 4rpx;
}

/* ========== 家庭口味 ========== */
.me__family-card {
  padding: 26rpx 30rpx 22rpx;
}

.me__family-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.me__family-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
}

.me__family-sub {
  font-size: 22rpx;
  color: #9B978F;
}

.me__member {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.me__member-emoji {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FFF1E2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.me__member-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #1F1B16;
  margin-right: 16rpx;
  min-width: 64rpx;
}

.me__member-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.me__member-tag {
  background: #FFF1E2;
  color: #A9743A;
  font-size: 21rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.me__pref-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FFF1E2;
  color: #EF6E00;
  font-size: 26rpx;
  font-weight: 500;
  padding: 18rpx 0;
  border-radius: 20rpx;
  margin-top: 14rpx;
}

.me__pref-icon {
  width: 28rpx;
  height: 28rpx;
}

/* ========== 单行卡（烹饪历史等） ========== */
.me__row-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 26rpx 30rpx;
}

.me__row-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.me__row-text {
  flex: 1;
  font-size: 28rpx;
  color: #1F1B16;
}

.me__row-arrow {
  width: 28rpx;
  height: 28rpx;
}

/* ========== 设置卡 ========== */
.me__settings-card {
  padding: 0 30rpx;
}

.me__set-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 24rpx 0;
}

.me__set-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.me__set-text {
  flex: 1;
  font-size: 28rpx;
  color: #1F1B16;
}

.me__set-arrow {
  width: 28rpx;
  height: 28rpx;
}

.me__set-tag {
  font-size: 21rpx;
  color: #9B978F;
  background: #F4F2EE;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.me__set-divider {
  height: 2rpx;
  background: #F4F2EE;
  margin-left: 58rpx;
  transform: scaleY(0.5);
}

/* ========== 退出登录 ========== */
.me__logout {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border: 2rpx solid #F2D8D2;
  border-radius: 28rpx;
  height: 88rpx;
  color: #E5604A;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 28rpx;
}

.me__logout-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.me__spacer { height: 80rpx; }
