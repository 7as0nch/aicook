<view class="inv">
  <custom-navbar title="冰箱库存">
    <view slot="right" class="inv__nav-btn inv__nav-btn--primary" bindtap="onAdd">
      <text>+</text>
    </view>
  </custom-navbar>

  <view class="inv__search">
    <image class="inv__search-icon" src="/assets/icons/search.png" mode="aspectFit" />
    <input
      class="inv__search-input"
      placeholder="搜索食材…"
      value="{{keyword}}"
      bindinput="onSearchInput"
    />
  </view>

  <scroll-view scroll-x enhanced="{{true}}" show-scrollbar="{{false}}" class="inv__tabs">
    <view class="inv__tabs-row">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="inv__tab {{activeTab === item.key ? 'inv__tab--active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onTabTap"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="inv__list">
    <view
      wx:for="{{filtered}}"
      wx:key="id"
      class="inv__item"
    >
      <view class="inv__item-icon">
        <image wx:if="{{item.icon_emoji}}" class="inv__item-img" src="{{item.icon_emoji}}" mode="aspectFit" />
        <text wx:else class="inv__item-emoji">🥗</text>
      </view>
      <view class="inv__item-body">
        <text class="inv__item-name">{{item.name}}</text>
        <text class="inv__item-meta">{{item.quantity_text || '—'}} {{item.expire_label ? ' · 距过期 ' + item.expire_label : ''}}</text>
      </view>
      <view class="inv__item-del" data-id="{{item.id}}" bindtap="onItemRemove">×</view>
    </view>

    <view wx:if="{{!filtered.length}}" class="inv__empty">
      <text class="inv__empty-emoji">🧊</text>
      <text class="inv__empty-text">冰箱空空，点 + 添加食材</text>
    </view>
  </view>

  <!-- 推荐能做的菜 -->
  <view wx:if="{{filtered.length}}" class="inv__cta" bindtap="onRecommendTap">
    <text class="inv__cta-icon">✨</text>
    <text>用现有食材推荐能做的菜</text>
  </view>

  <view class="inv__spacer"></view>

  <!-- 添加食材弹层（替代已弃用的 wx.showModal editable） -->
  <view wx:if="{{addVisible}}" class="inv__mask" bindtap="onAddClose" catchtouchmove="noop"></view>
  <view wx:if="{{addVisible}}" class="inv__sheet" catchtouchmove="noop">
    <view class="inv__sheet-title">添加食材</view>
    <input
      class="inv__sheet-input"
      placeholder="食材名，如：番茄"
      value="{{addName}}"
      bindinput="onAddNameInput"
      focus="{{addVisible}}"
      confirm-type="next"
      maxlength="30"
    />
    <input
      class="inv__sheet-input"
      placeholder="数量（可选），如：3 个"
      value="{{addQty}}"
      bindinput="onAddQtyInput"
      confirm-type="done"
      bindconfirm="onAddConfirm"
      maxlength="20"
    />
    <view class="inv__sheet-actions">
      <view class="inv__sheet-btn" bindtap="onAddClose">取消</view>
      <view
        class="inv__sheet-btn inv__sheet-btn--primary {{addSaving ? 'inv__sheet-btn--disabled' : ''}}"
        bindtap="onAddConfirm"
      >{{addSaving ? '添加中…' : '确认添加'}}</view>
    </view>
    <view class="inv__sheet-safe"></view>
  </view>
</view>
