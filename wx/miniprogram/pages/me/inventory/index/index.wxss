.inv {
  min-height: 100vh;
  background: #FAFAF8;
  padding-bottom: 80rpx;
}

.inv__navbar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  padding-top: env(safe-area-inset-top);
  box-sizing: content-box;
  background: #FFFFFF;
  border-bottom: 2rpx solid #EFEDE8;
  gap: 16rpx;
}

.inv__nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inv__nav-btn--primary {
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 300;
}

.inv__nav-icon {
  width: 40rpx;
  height: 40rpx;
}

.inv__nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-right: 72rpx;
}

.inv__search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F4F5F7;
  border-radius: 46rpx;
  padding: 0 28rpx;
  height: 88rpx;
  margin: 28rpx 48rpx 0;
}

.inv__search-icon {
  width: 36rpx;
  height: 36rpx;
}

.inv__search-input {
  flex: 1;
  font-size: 27rpx;
  color: #1F1B16;
}

.inv__tabs {
  width: 100%;
  white-space: nowrap;
  margin: 28rpx 0;
  padding-left: 48rpx;
}

.inv__tabs-row {
  display: inline-flex;
  gap: 16rpx;
}

.inv__tab {
  padding: 12rpx 28rpx;
  background: #F4F5F7;
  color: #6E6A62;
  font-size: 26rpx;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.inv__tab--active {
  background: #FF7A00;
  color: #FFFFFF;
  font-weight: 500;
}

.inv__list {
  margin: 0 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 8rpx 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.inv__item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F4F2EE;
}

.inv__item:last-child {
  border-bottom: 0;
}

.inv__item-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.inv__item-img {
  width: 56rpx;
  height: 56rpx;
}

.inv__item-emoji {
  font-size: 44rpx;
}

.inv__item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.inv__item-name {
  font-size: 29rpx;
  font-weight: 600;
  color: #1F1B16;
}

.inv__item-meta {
  font-size: 23rpx;
  color: #9B978F;
}

.inv__item-del {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F4F5F7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  color: #9B978F;
}

.inv__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.inv__empty-emoji {
  font-size: 72rpx;
}

.inv__empty-text {
  color: #9B978F;
  font-size: 26rpx;
}

.inv__cta {
  margin: 32rpx 48rpx 0;
  background: linear-gradient(135deg, #FFB366 0%, #FF7A00 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 0;
  text-align: center;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 28rpx rgba(255, 122, 0, 0.32);
}

.inv__cta-icon {
  font-size: 30rpx;
}

.inv__spacer { height: 60rpx; }
