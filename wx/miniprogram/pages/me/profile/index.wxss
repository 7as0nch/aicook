.prof {
  min-height: 100vh;
  background: #FAFAF8;
}

.prof__navbar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  padding-top: env(safe-area-inset-top);
  box-sizing: content-box;
  background: #FFFFFF;
  gap: 16rpx;
  border-bottom: 1rpx solid #F4F2EE;
}

.prof__nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prof__nav-icon { width: 36rpx; height: 36rpx; }

.prof__nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
}

.prof__nav-save {
  padding: 14rpx 32rpx;
  background: #FF7A00;
  color: #FFFFFF;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.prof__nav-save--saving { background: #DDD8D0; }

.prof__avatar-row {
  padding: 64rpx 32rpx 48rpx;
  text-align: center;
}

.prof__avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.prof__avatar-img { width: 100%; height: 100%; }

.prof__avatar-default { width: 100rpx; height: 100rpx; opacity: 0.6; }

.prof__avatar-tip {
  font-size: 24rpx;
  color: #FF7A00;
}

.prof__card {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 27, 22, 0.06);
  overflow: hidden;
}

.prof__field {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F4F2EE;
  gap: 24rpx;
}

.prof__field:last-child { border-bottom: none; }

.prof__label {
  width: 140rpx;
  font-size: 28rpx;
  color: #9B978F;
  flex-shrink: 0;
}

.prof__input {
  flex: 1;
  font-size: 30rpx;
  color: #1F1B16;
}

.prof__readonly {
  flex: 1;
  font-size: 30rpx;
  color: #1F1B16;
}

.prof__spacer { height: 80rpx; }
