<view class="plan">
  <view class="plan__head">
    <view class="plan__head-titles">
      <text class="plan__title">用餐计划</text>
      <text class="plan__subtitle">一日三餐 · 一键生成采购清单</text>
    </view>
    <view class="plan__cart-btn" bindtap="onShoppingTap">
      <image class="plan__cart-icon" src="/assets/icons/cart.svg" mode="aspectFit" />
    </view>
  </view>

  <view class="plan__week-card">
    <view class="plan__week-head">
      <text class="plan__week-title">本周</text>
      <text class="plan__week-range">{{weekRangeLabel}}</text>
    </view>
    <view class="plan__week-days">
      <view
        wx:for="{{weekDays}}"
        wx:key="date"
        class="plan__day {{item.date === selectedDate ? 'plan__day--active' : ''}}"
        data-date="{{item.date}}"
        bindtap="onDayTap"
      >
        <view class="plan__day-name">{{item.label}}</view>
        <view class="plan__day-num">{{item.day}}</view>
      </view>
    </view>
  </view>

  <view class="plan__meal-card">
    <view class="plan__meal-head">
      <view class="plan__meal-emoji">🥐</view>
      <view class="plan__meal-titles">
        <text class="plan__meal-name">早餐</text>
        <text class="plan__meal-time">07:30 · {{breakfast.length}} 道</text>
      </view>
      <view class="plan__meal-add" data-type="breakfast" bindtap="onMealAdd">
        <image class="plan__meal-add-icon" src="/assets/icons/plus.svg" mode="aspectFit" />
      </view>
    </view>
    <view wx:if="{{breakfast.length}}" class="plan__meal-divider"></view>
    <block wx:for="{{breakfast}}" wx:key="key" wx:for-item="dish">
      <view wx:if="{{index > 0}}" class="plan__dish-divider"></view>
      <view class="plan__dish-row" data-id="{{dish.recipeId}}" bindtap="onDishTap">
        <view class="plan__dish-img"></view>
        <view class="plan__dish-body">
          <text class="plan__dish-name">{{dish.title}}</text>
          <text wx:if="{{dish.note}}" class="plan__dish-meta">{{dish.note}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{!breakfast.length}}" class="plan__empty-tip">暂无早餐，点击右上 + 添加</view>
  </view>

  <view class="plan__meal-card">
    <view class="plan__meal-head">
      <view class="plan__meal-emoji">🍱</view>
      <view class="plan__meal-titles">
        <text class="plan__meal-name">午餐</text>
        <text class="plan__meal-time">12:00 · {{lunch.length}} 道</text>
      </view>
      <view class="plan__meal-add" data-type="lunch" bindtap="onMealAdd">
        <image class="plan__meal-add-icon" src="/assets/icons/plus.svg" mode="aspectFit" />
      </view>
    </view>
    <view wx:if="{{lunch.length}}" class="plan__meal-divider"></view>
    <block wx:for="{{lunch}}" wx:key="key" wx:for-item="dish">
      <view wx:if="{{index > 0}}" class="plan__dish-divider"></view>
      <view class="plan__dish-row" data-id="{{dish.recipeId}}" bindtap="onDishTap">
        <view class="plan__dish-img"></view>
        <view class="plan__dish-body">
          <text class="plan__dish-name">{{dish.title}}</text>
          <text wx:if="{{dish.note}}" class="plan__dish-meta">{{dish.note}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{!lunch.length}}" class="plan__empty-tip">暂无午餐，点击右上 + 添加</view>
  </view>

  <view class="plan__meal-card">
    <view class="plan__meal-head">
      <view class="plan__meal-emoji">🍲</view>
      <view class="plan__meal-titles">
        <text class="plan__meal-name">晚餐</text>
        <text class="plan__meal-time">18:30 · {{dinner.length}} 道</text>
      </view>
      <view class="plan__meal-add" data-type="dinner" bindtap="onMealAdd">
        <image class="plan__meal-add-icon" src="/assets/icons/plus.svg" mode="aspectFit" />
      </view>
    </view>
    <view wx:if="{{dinner.length}}" class="plan__meal-divider"></view>
    <block wx:for="{{dinner}}" wx:key="key" wx:for-item="dish">
      <view wx:if="{{index > 0}}" class="plan__dish-divider"></view>
      <view class="plan__dish-row" data-id="{{dish.recipeId}}" bindtap="onDishTap">
        <view class="plan__dish-img"></view>
        <view class="plan__dish-body">
          <text class="plan__dish-name">{{dish.title}}</text>
          <text wx:if="{{dish.note}}" class="plan__dish-meta">{{dish.note}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{!dinner.length}}" class="plan__empty-tip">暂无晚餐，点击右上 + 添加</view>
  </view>

  <view class="plan__shopping-card" bindtap="onShoppingTap">
    <view class="plan__shopping-head">
      <image class="plan__shopping-cart" src="/assets/icons/cart.svg" mode="aspectFit" />
      <text class="plan__shopping-title">本周采购清单</text>
      <text class="plan__shopping-count">已采购 {{shoppingCheckedCount}} / {{shoppingTotal}}</text>
      <image class="plan__shopping-arrow" src="/assets/icons/right.svg" mode="aspectFit" />
    </view>
    <view class="plan__shopping-progress">
      <view class="plan__shopping-progress-fill" style="width: {{shoppingProgressPct}}%"></view>
    </view>
    <text class="plan__shopping-preview">{{shoppingPreviewText || '暂无采购项'}}</text>
  </view>

  <view class="plan__ai-btn" bindtap="onGeneratePlan">
    <text>✨ AI 一键生成本周计划</text>
  </view>

  <view class="plan__spacer"></view>
</view>

<ai-fab />
<ai-sheet context="计划" />
