.plan {
  min-height: 100vh;
  background: #FAFAF8;
  padding: 0 48rpx 220rpx;
}

.plan__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 28rpx;
}

.plan__head-titles {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.plan__title {
  font-size: 46rpx;
  font-weight: 700;
  color: #1F1B16;
  line-height: 1.1;
}

.plan__subtitle {
  font-size: 25rpx;
  color: #9B978F;
}

.plan__cart-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plan__cart-icon {
  width: 40rpx;
  height: 40rpx;
}

.plan__week-card {
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.plan__week-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.plan__week-title {
  font-size: 27rpx;
  font-weight: 600;
  color: #1F1B16;
}

.plan__week-range {
  font-size: 23rpx;
  color: #9B978F;
}

.plan__week-days {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
}

.plan__day {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 6rpx 0;
  gap: 8rpx;
}

.plan__day-name {
  font-size: 21rpx;
  color: #9B978F;
  line-height: 1;
}

.plan__day-num {
  width: 60rpx;
  height: 48rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #1F1B16;
}

.plan__day--active .plan__day-name {
  color: #EF6E00;
}

.plan__day--active .plan__day-num {
  background: #FF7A00;
  color: #FFFFFF;
  font-weight: 600;
}

.plan__meal-card {
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.plan__meal-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.plan__meal-emoji {
  width: 80rpx;
  height: 80rpx;
  border-radius: 26rpx;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  flex-shrink: 0;
}

.plan__meal-titles {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.plan__meal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
  line-height: 1.1;
}

.plan__meal-time {
  font-size: 23rpx;
  color: #9B978F;
}

.plan__meal-add {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plan__meal-add-icon {
  width: 36rpx;
  height: 36rpx;
}

.plan__meal-divider {
  height: 2rpx;
  background: #EFEDE8;
  margin: 20rpx -28rpx 20rpx;
}

.plan__dish-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.plan__dish-divider {
  height: 2rpx;
  background: #F4F2EE;
  margin: 16rpx 0 16rpx 102rpx;
}

.plan__dish-img {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #FFEAD2 0%, #FFD6AA 100%);
  overflow: hidden;
  flex-shrink: 0;
}

.plan__dish-img-i { width: 100%; height: 100%; }

.plan__dish-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.plan__dish-name {
  font-size: 27rpx;
  font-weight: 500;
  color: #1F1B16;
  line-height: 1.2;
}

.plan__dish-meta {
  font-size: 22rpx;
  color: #9B978F;
}

.plan__dish-cal {
  background: #FFF6EE;
  color: #EF6E00;
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.plan__empty-tip {
  text-align: center;
  color: #9B978F;
  font-size: 23rpx;
  padding: 18rpx 0 4rpx;
}

.plan__shopping-card {
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.plan__shopping-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.plan__shopping-cart {
  width: 36rpx;
  height: 36rpx;
}

.plan__shopping-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1F1B16;
}

.plan__shopping-count {
  font-size: 23rpx;
  color: #9B978F;
  margin-right: 8rpx;
}

.plan__shopping-arrow {
  width: 28rpx;
  height: 28rpx;
}

.plan__shopping-progress {
  height: 14rpx;
  background: #F4F5F7;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.plan__shopping-progress-fill {
  height: 100%;
  background: #FF7A00;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.plan__shopping-preview {
  font-size: 22rpx;
  color: #9B978F;
}

.plan__ai-btn {
  background: linear-gradient(135deg, #FFB366 0%, #FF7A00 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 28rpx rgba(255, 122, 0, 0.32);
}

.plan__spacer { height: 80rpx; }
