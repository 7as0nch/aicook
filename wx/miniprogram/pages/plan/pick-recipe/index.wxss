.pick {
  min-height: 100vh;
  background: #FAFAF8;
  padding-bottom: 80rpx;
}

.pick__date {
  margin: 24rpx 48rpx 0;
  font-size: 24rpx;
  color: #9B978F;
}

.pick__search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F4F5F7;
  border-radius: 46rpx;
  padding: 0 28rpx;
  height: 88rpx;
  margin: 20rpx 48rpx 0;
}

.pick__search-icon {
  width: 36rpx;
  height: 36rpx;
}

.pick__search-input {
  flex: 1;
  font-size: 27rpx;
  color: #1F1B16;
}

.pick__list {
  margin: 28rpx 48rpx 0;
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 8rpx 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.pick__item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F4F2EE;
}

.pick__item:last-child {
  border-bottom: 0;
}

.pick__item-img {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.pick__item-img-i {
  width: 100%;
  height: 100%;
}

.pick__item-emoji {
  font-size: 40rpx;
}

.pick__item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.pick__item-name {
  font-size: 29rpx;
  font-weight: 600;
  color: #1F1B16;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pick__item-meta {
  font-size: 23rpx;
  color: #9B978F;
}

.pick__item-add {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FFF6EE;
  color: #FF7A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  flex-shrink: 0;
}

.pick__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.pick__empty-emoji {
  font-size: 72rpx;
}

.pick__empty-text {
  color: #9B978F;
  font-size: 26rpx;
}

.pick__spacer { height: 60rpx; }
