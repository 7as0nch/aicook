.ck {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 200rpx;
}

.ck__navbar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  padding-top: env(safe-area-inset-top);
  box-sizing: content-box;
  background: linear-gradient(180deg, #FFF6EE 0%, #FFFFFF 100%);
  gap: 16rpx;
}

.ck__nav-btn,
.ck__nav-back,
.ck__nav-ai {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(31, 27, 22, 0.06);
  flex-shrink: 0;
}

.ck__nav-icon { width: 36rpx; height: 36rpx; }

/* 返回图标必须显式约束尺寸，否则 <image> 用默认大图把导航撑爆 */
.ck__nav-back-icon { width: 32rpx; height: 32rpx; }

.ck__nav-ai-icon { width: 40rpx; height: 40rpx; }

.ck__nav-body {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.ck__nav-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.ck__nav-sub {
  display: block;
  font-size: 22rpx;
  color: #9B978F;
  margin-top: 4rpx;
}

.ck__progress {
  height: 6rpx;
  background: #F4F2EE;
  margin: 8rpx 24rpx 0;
  border-radius: 9999rpx;
  overflow: hidden;
}

.ck__progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFB366 0%, #FF7A00 100%);
  transition: width 0.3s;
}

.ck__body {
  padding: 32rpx;
}

/* 步骤标签 */
.ck__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.ck__tag {
  padding: 6rpx 20rpx;
  border-radius: 9999rpx;
  background: #FFF1E6;
  color: #E5604A;
  font-size: 22rpx;
  font-weight: 500;
}

/* 多媒体步骤 */
.ck__media { margin-bottom: 28rpx; }

.ck__media-hero {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  height: 360rpx;
  background: #F4F5F7;
}

.ck__media-hero-img { width: 100%; height: 100%; }

.ck__media-count {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  padding: 4rpx 18rpx;
  background: rgba(31, 27, 22, 0.55);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 9999rpx;
}

.ck__media-thumbs {
  white-space: nowrap;
  margin-top: 16rpx;
}

.ck__media-thumb {
  display: inline-block;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 12rpx;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.ck__media-thumb--on { border-color: #FF7A00; }

.ck__media-thumb-img { width: 100%; height: 100%; }

.ck__step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F1B16;
  margin-bottom: 16rpx;
}

.ck__step-desc {
  font-size: 32rpx;
  line-height: 1.6;
  color: #1F1B16;
  margin-bottom: 32rpx;
}

.ck__timer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: #FFF6EE;
  border-radius: 32rpx;
  margin: 32rpx 0;
}

/* 倒计时圆环（conic-gradient 进度 + 内圈白底） */
.ck__ring {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ck__ring-inner {
  width: 244rpx;
  height: 244rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 8rpx rgba(255, 122, 0, 0.06);
}

.ck__ring-label {
  font-size: 24rpx;
  color: #9B978F;
  margin-bottom: 6rpx;
}

.ck__ring-time {
  font-size: 76rpx;
  font-weight: 700;
  color: #FF7A00;
  font-variant-numeric: tabular-nums;
}

.ck__timer-status {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #9B978F;
}

.ck__timer-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.ck__timer-btn {
  padding: 18rpx 40rpx;
  background: #FF7A00;
  color: #FFFFFF;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.ck__timer-btn--ghost {
  background: #FFFFFF;
  color: #FF7A00;
  border: 2rpx solid #FFD2AC;
}

/* 预计完成条件 */
.ck__cond {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F0FAF3;
  margin-top: 24rpx;
}
.ck__cond-label { font-size: 24rpx; font-weight: 600; color: #2D9D62; }
.ck__cond-text { font-size: 28rpx; line-height: 1.5; color: #1F1B16; }

.ck__tip {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  margin-top: 24rpx;
}

.ck__tip--warn {
  background: #FFF4E5;
  color: #B45309;
}

.ck__tip--ai {
  background: #EEF6FF;
  color: #1E40AF;
}

.ck__tip-label {
  font-size: 24rpx;
  font-weight: 600;
}

.ck__tip text:not(.ck__tip-label) {
  font-size: 26rpx;
  line-height: 1.5;
}

.ck__bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #F4F2EE;
  display: flex;
  gap: 16rpx;
}

.ck__bottom-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.ck__bottom-btn--ghost {
  background: #F4F5F7;
  color: #5C544A;
}

.ck__bottom-btn--primary {
  background: #FF7A00;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 0, 0.32);
}

.ck__bottom-btn--disabled {
  opacity: 0.4;
}

.ck__spacer { height: 80rpx; }
