<view class="rd">
  <!-- Hero 图 -->
  <view class="rd__hero">
    <image wx:if="{{recipe.cover_image_url}}" class="rd__hero-img" src="{{recipe.cover_image_url}}" mode="aspectFill" />
    <view class="rd__hero-overlay"></view>
  </view>

  <!-- 顶部导航：统一 custom-navbar（叠加在 hero 上）；左返回内置，右侧编辑/分享走右插槽（胶囊安全） -->
  <custom-navbar overlay border="{{false}}">
    <view slot="right" class="rd__nav-actions">
      <view wx:if="{{canEdit}}" class="rd__nav-btn rd__nav-btn--edit" bindtap="onEditTap">
        <text class="rd__nav-edit-text">编辑</text>
      </view>
      <!-- 圆圈与对齐用 view 控制（可靠）；原生转发用一个透明 button 盖在上面：
           点按=转发给好友（open-type=share，不走接口）、长按=复制分享码 -->
      <view class="rd__nav-btn rd__nav-btn--share">
        <image class="rd__nav-icon" src="/assets/icons/share.svg" mode="aspectFit" />
        <button class="rd__nav-share-hit" open-type="share" hover-class="none" bindlongpress="onCopyShareCode"></button>
      </view>
    </view>
  </custom-navbar>

  <!-- 内容卡 -->
  <view class="rd__sheet">
    <view class="rd__title">{{recipe.title || '加载中…'}}</view>

    <view class="rd__chips">
      <view wx:if="{{recipe.category}}" class="rd__chip">{{recipe.category}}</view>
      <view wx:if="{{recipe.total_minutes}}" class="rd__chip">{{recipe.total_minutes}}分钟</view>
      <view wx:if="{{recipe.difficulty}}" class="rd__chip">{{difficultyLabel}}</view>
      <view wx:if="{{recipe.servings}}" class="rd__chip">{{recipe.servings}}人</view>
    </view>

    <view class="rd__divider"></view>

    <!-- 4 tab -->
    <view class="rd__tabs">
      <view class="rd__tab {{activeTab === 'ingredients' ? 'rd__tab--active' : ''}}" data-tab="ingredients" bindtap="onTabSwitch">
        食材
        <view wx:if="{{activeTab === 'ingredients'}}" class="rd__tab-bar"></view>
      </view>
      <view class="rd__tab {{activeTab === 'steps' ? 'rd__tab--active' : ''}}" data-tab="steps" bindtap="onTabSwitch">
        步骤
        <view wx:if="{{activeTab === 'steps'}}" class="rd__tab-bar"></view>
      </view>
      <view class="rd__tab {{activeTab === 'nutrition' ? 'rd__tab--active' : ''}}" data-tab="nutrition" bindtap="onTabSwitch">
        营养
        <view wx:if="{{activeTab === 'nutrition'}}" class="rd__tab-bar"></view>
      </view>
    </view>

    <view class="rd__divider"></view>

    <!-- 食材 -->
    <view wx:if="{{activeTab === 'ingredients'}}" class="rd__panel">
      <block wx:for="{{ingredientGroups}}" wx:key="groupName" wx:for-item="grp">
        <view class="rd__ing-group">
          <view class="rd__ing-grp-name">{{grp.groupName}}</view>
          <view wx:for="{{grp.items}}" wx:key="name" wx:for-item="ing" class="rd__ing-row">
            <text class="rd__ing-name">{{ing.name}}</text>
            <text class="rd__ing-amt">{{ing.amount}} {{ing.unit}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{!ingredientGroups.length}}" class="rd__empty">暂无食材数据</view>
    </view>

    <!-- 步骤 -->
    <view wx:if="{{activeTab === 'steps'}}" class="rd__panel">
      <view wx:for="{{steps}}" wx:key="step_no" wx:for-item="step" class="rd__step">
        <view class="rd__step-no">{{step.step_no || index + 1}}</view>
        <view wx:if="{{index < steps.length - 1}}" class="rd__step-line"></view>
        <view class="rd__step-body">
          <view class="rd__step-title">{{step.title || ('步骤 ' + (step.step_no || index + 1))}}</view>
          <view class="rd__step-desc">{{step.description}}</view>
        </view>
        <view class="rd__step-img">
          <image wx:if="{{step.cover_image_url}}" class="rd__step-img-i" src="{{step.cover_image_url}}" mode="aspectFill" />
        </view>
      </view>
      <view wx:if="{{!steps.length}}" class="rd__empty">暂无步骤</view>
    </view>

    <!-- 营养 -->
    <view wx:if="{{activeTab === 'nutrition'}}" class="rd__panel">
      <view class="rd__empty">营养数据敬请期待</view>
    </view>

    <view class="rd__sheet-spacer"></view>
  </view>

  <!-- 底部 sticky 操作栏 -->
  <view class="rd__footer">
    <view class="rd__fav-btn {{favored ? 'rd__fav-btn--on' : ''}}" bindtap="onFavTap">
      <image class="rd__fav-icon" src="{{favored ? '/assets/icons/star-fill.svg' : '/assets/icons/star-line.svg'}}" mode="aspectFit" />
      <text class="rd__fav-text">{{favored ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="rd__cook-btn" bindtap="onCookTap">
      <image class="rd__cook-icon" src="/assets/icons/play.svg" mode="aspectFit" />
      <text>开始烹饪</text>
    </view>
  </view>
</view>

<!-- 全局 AI 浮球：携带本页菜谱上下文（让助手知道你在看哪道菜） -->
<ai-fab scene="recipe_detail" recipeId="{{id}}" contextHint="{{recipe.title}}" bottom="240rpx" />
<ai-sheet context="{{recipe.title || '菜谱详情'}}" />
