.rd {
  min-height: 100vh;
  background: #FFFFFF;
  position: relative;
}

/* ========== Hero 图 ========== */
.rd__hero {
  position: relative;
  width: 100%;
  height: 600rpx;
  background: linear-gradient(180deg, #FFE0BC 0%, #FFC987 100%);
  overflow: hidden;
}

.rd__hero-img { width: 100%; height: 100%; }

.rd__hero-overlay {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 200rpx;
  background: linear-gradient(180deg, rgba(31, 27, 22, 0.32) 0%, rgba(31, 27, 22, 0) 100%);
}

/* ========== 顶部导航右侧操作（custom-navbar slot="right"） ========== */
.rd__nav-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rd__nav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(31, 20, 8, 0.12);
}

.rd__nav-icon {
  width: 34rpx;
  height: 34rpx;
}

/* 编辑入口（仅本家庭菜谱显示）*/
.rd__nav-btn--edit {
  width: auto;
  padding: 0 24rpx;
  border-radius: 32rpx;
}

.rd__nav-edit-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FF7A00;
}

/* 分享按钮：橙色实心圆（share 图标是白色，放白底会“隐身”）。圆圈与对齐由 view 控制，
   转发能力由内部透明 button(open-type=share) 提供，避开微信 button 的默认块级宽度/对齐问题 */
.rd__nav-btn--share {
  position: relative;
  background: #FF7A00;
  box-shadow: 0 4rpx 14rpx rgba(255, 122, 0, 0.4);
}

.rd__nav-share-hit {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  min-width: 0;
  padding: 0;
  margin: 0;
  line-height: 1;
  opacity: 0;
  background: transparent;
}

.rd__nav-share-hit::after {
  border: none;
}

/* ========== 内容卡 ========== */
.rd__sheet {
  position: relative;
  margin-top: -56rpx;
  background: #FFFFFF;
  border-top-left-radius: 56rpx;
  border-top-right-radius: 56rpx;
  padding: 56rpx 48rpx 0;
  box-shadow: 0 -8rpx 44rpx rgba(0, 0, 0, 0.08);
  z-index: 10;
}

.rd__title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F1B16;
  line-height: 1.1;
  margin-bottom: 20rpx;
}

.rd__chips {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.rd__chip {
  background: #FFF6EE;
  color: #A9743A;
  font-size: 23rpx;
  padding: 8rpx 20rpx;
  border-radius: 26rpx;
  line-height: 1.2;
}

.rd__match {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 25rpx;
  color: #2DBE7A;
  margin-bottom: 24rpx;
}

.rd__match-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2DBE7A;
}

.rd__divider {
  height: 2rpx;
  background: #EFEDE8;
  margin: 0 -48rpx;
}

/* ========== Tabs ========== */
.rd__tabs {
  display: flex;
  justify-content: space-between;
  padding: 28rpx 0;
}

.rd__tab {
  flex: 1;
  text-align: center;
  font-size: 29rpx;
  color: #9B978F;
  position: relative;
  padding-bottom: 14rpx;
}

.rd__tab--active {
  color: #1F1B16;
  font-weight: 600;
}

.rd__tab-bar {
  position: absolute;
  left: 50%;
  bottom: -4rpx;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #FF7A00;
  border-radius: 4rpx;
}

/* ========== Panels ========== */
.rd__panel {
  padding: 20rpx 0 32rpx;
}

.rd__empty {
  text-align: center;
  color: #9B978F;
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* 食材 */
.rd__ing-group {
  margin-bottom: 24rpx;
}

.rd__ing-grp-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-bottom: 12rpx;
}

.rd__ing-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #F4F2EE;
}

.rd__ing-name {
  font-size: 27rpx;
  color: #1F1B16;
}

.rd__ing-amt {
  font-size: 25rpx;
  color: #9B978F;
}

/* 步骤 */
.rd__step {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 16rpx 0 32rpx;
}

.rd__step-no {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.rd__step-line {
  position: absolute;
  top: 72rpx;
  left: 26rpx;
  width: 4rpx;
  bottom: -16rpx;
  background: #F2E7D6;
  z-index: 0;
}

.rd__step-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  padding-top: 6rpx;
}

.rd__step-title {
  font-size: 31rpx;
  font-weight: 600;
  color: #1F1B16;
}

.rd__step-desc {
  font-size: 25rpx;
  color: #9B978F;
  line-height: 1.5;
}

.rd__step-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #FFEAD2 0%, #FFD6AA 100%);
  flex-shrink: 0;
  overflow: hidden;
}

.rd__step-img-i { width: 100%; height: 100%; }

.rd__sheet-spacer { height: 240rpx; }

/* ========== 底部 sticky ========== */
.rd__footer {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #FFFFFF;
  padding: 16rpx 48rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  align-items: center;
  border-top: 2rpx solid #EFEDE8;
  z-index: 50;
}

.rd__fav-btn {
  width: 132rpx;
  height: 108rpx;
  border-radius: 28rpx;
  background: #F4F2EE;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex-shrink: 0;
}

/* 已收藏：实心橙星 + 橙底描边 + 橙字，和未收藏（灰星灰底）形成强对比 */
.rd__fav-btn--on {
  background: #FFEAD9;
  border-color: #FF7A00;
}

.rd__fav-icon {
  width: 44rpx;
  height: 44rpx;
}

.rd__fav-text {
  font-size: 20rpx;
  color: #9B978F;
}

.rd__fav-btn--on .rd__fav-text {
  color: #FF7A00;
  font-weight: 600;
}

.rd__cook-btn {
  flex: 1;
  height: 108rpx;
  background: #FF7A00;
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(31, 20, 8, 0.28);
}

.rd__cook-icon {
  width: 40rpx;
  height: 40rpx;
}
