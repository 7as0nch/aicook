<view class="rl">
  <!-- 顶部 -->
  <view class="rl__header">
    <text class="rl__title">菜谱</text>
    <view class="rl__new" bindtap="onWorkbenchTap">
      <image class="rl__new-icon" src="/assets/icons/plus.svg" mode="aspectFit" />
      <text>新建</text>
    </view>
  </view>

  <!-- 搜索 -->
  <view class="rl__search">
    <image class="rl__search-ic" src="/assets/icons/search.png" mode="aspectFit" />
    <input
      class="rl__search-input"
      placeholder="搜索菜谱、食材、做法…"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      bindconfirm="onSearchConfirm"
      confirm-type="search"
    />
  </view>

  <!-- 美团式：左类目 + 右菜谱 -->
  <view class="rl__body">
    <!-- 左类目栏 -->
    <scroll-view scroll-y class="rl__side" show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:for-item="cat"
        wx:key="id"
        class="rl__side-item {{activeCat === cat.id ? 'rl__side-item--on' : ''}}"
        data-id="{{cat.id}}"
        data-name="{{cat.name}}"
        data-deletable="{{cat.deletable}}"
        bindtap="onCategoryTap"
        bindlongpress="onCategoryLongpress"
      >
        <text>{{cat.label}}</text>
      </view>
      <view class="rl__side-add" bindtap="onAddCategory">＋ 新建类目</view>
    </scroll-view>

    <!-- 右菜谱列 -->
    <scroll-view scroll-y class="rl__main" show-scrollbar="{{false}}">
      <view
        wx:for="{{recipes}}"
        wx:for-item="r"
        wx:key="id"
        class="rl__row"
        data-id="{{r.id}}"
        bindtap="onRecipeTap"
      >
        <view class="rl__row-cover">
          <image wx:if="{{r.cover_image_url}}" class="rl__row-cover-img" src="{{r.cover_image_url}}" mode="aspectFill" />
        </view>
        <view class="rl__row-body">
          <text class="rl__row-title">{{r.title}}</text>
          <text wx:if="{{r.__meta}}" class="rl__row-meta">{{r.__meta}}</text>
          <view class="rl__row-actions">
            <view class="rl__row-btn" data-id="{{r.id}}" catchtap="onEditRecipe">编辑</view>
            <view class="rl__row-btn rl__row-btn--del" data-id="{{r.id}}" catchtap="onDeleteRecipe">删除</view>
          </view>
        </view>
      </view>

      <view wx:if="{{!recipes.length && !loading}}" class="rl__empty">
        <text>该类目下暂无菜谱</text>
        <view class="rl__empty-btn" bindtap="onWorkbenchTap">＋ 新建菜谱</view>
      </view>
      <view class="rl__main-spacer"></view>
    </scroll-view>
  </view>
</view>

<ai-fab scene="chat" contextHint="菜谱库" />
<ai-sheet context="菜谱浏览" />

<!-- 新建类目 -->
<input-dialog
  visible="{{catDialogVisible}}"
  title="新建类目"
  placeholder="输入类目名称，如 家常菜"
  confirmText="创建"
  maxlength="20"
  bind:confirm="onCatDialogConfirm"
  bind:close="onCatDialogClose"
/>
