<view class="recipes-page">
  <!-- 顶部 -->
  <view class="page-header">
    <text class="page-title">菜谱</text>
    <text class="page-action">编辑</text>
  </view>

  <!-- 搜索 -->
  <view class="search-bar">
    <view class="icon-slot size-sm">
      <text class="icon-slot__emoji">🔍</text>
    </view>
    <input class="search-input" placeholder="搜索菜谱、食材、做法…" value="{{keyword}}" bindinput="onKeywordInput" />
    <view class="icon-slot size-sm">
      <text class="icon-slot__emoji">🎚️</text>
    </view>
  </view>

  <!-- 标签筛选 -->
  <scroll-view class="filter-scroll" scroll-x>
    <view class="filter-row">
      <view
        class="filter-chip {{activeFilter === item.id ? 'active' : ''}}"
        wx:for="{{filters}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onFilterTap"
      >
        {{item.text}}
      </view>
    </view>
  </scroll-view>

  <!-- 今日常做 -->
  <view class="section">
    <view class="section-title">
      <text class="title-main">今日常做</text>
      <text class="title-link">查看全部 ›</text>
    </view>
    <view class="grid-2">
      <view
        class="recipe-card"
        wx:for="{{todayPicks}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onRecipeTap"
      >
        <view class="card-cover img-placeholder">
          <image wx:if="{{item.cover}}" class="card-cover-img" src="{{item.cover}}" mode="aspectFill"></image>
          <text wx:else class="cover-emoji">{{item.coverFallback}}</text>
        </view>
        <view class="card-body">
          <text class="card-title">{{item.title}}</text>
          <view class="card-meta">
            <text>{{item.minutes}}分钟·{{item.difficulty}}</text>
          </view>
          <view class="card-fav">
            <view class="icon-slot size-sm"><text class="icon-slot__emoji">❤️</text></view>
            <text class="fav-count">{{item.favorites}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 按类型浏览 -->
  <view class="section">
    <view class="section-title">
      <text class="title-main">按类型浏览</text>
    </view>
    <view class="cat-grid">
      <view
        class="cat-cell"
        wx:for="{{categories}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCategoryTap"
      >
        <view class="cat-cover img-placeholder">
          <image wx:if="{{item.iconSrc}}" class="cat-cover-img" src="{{item.iconSrc}}" mode="aspectFit"></image>
          <text wx:else class="cover-emoji small">{{item.iconFallback}}</text>
        </view>
        <text class="cat-label">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 我的菜谱 -->
  <view class="section">
    <view class="section-title">
      <text class="title-main">我的菜谱</text>
    </view>
    <view class="my-list">
      <view class="my-item">
        <view class="icon-slot size-sm"><text class="icon-slot__emoji">📚</text></view>
        <text class="my-text">全部菜谱</text>
        <text class="my-count">{{myCounts.total}}</text>
        <text class="my-arrow">›</text>
      </view>
      <view class="my-item">
        <view class="icon-slot size-sm"><text class="icon-slot__emoji">📝</text></view>
        <text class="my-text">草稿箱</text>
        <text class="my-count">{{myCounts.drafts}}</text>
        <text class="my-arrow">›</text>
      </view>
      <view class="my-item">
        <view class="icon-slot size-sm"><text class="icon-slot__emoji">🗑️</text></view>
        <text class="my-text">最近删除</text>
        <text class="my-count">{{myCounts.recentDeleted}}</text>
        <text class="my-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>

<ai-fab />
<ai-sheet context="菜谱浏览" />
