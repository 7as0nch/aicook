.recipes-page {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 0 24rpx 200rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0 16rpx;
}

.page-title {
  font-size: 50rpx;
  font-weight: 700;
  color: #1F1B16;
}

.page-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 22rpx;
  background: #FFF6EE;
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: #FF7A00;
}

.page-action-icon { width: 30rpx; height: 30rpx; }

.search-bar {
  display: flex;
  align-items: center;
  background: #F4F5F7;
  border-radius: 9999rpx;
  padding: 16rpx 24rpx;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.search-icon { width: 30rpx; height: 30rpx; opacity: 0.7; }
.search-filter { width: 32rpx; height: 32rpx; opacity: 0.7; }

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1F1B16;
}

.filter-scroll { white-space: nowrap; }
.filter-row { display: inline-flex; gap: 12rpx; padding: 8rpx 0 16rpx; }
.filter-chip {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: #F4F5F7;
  border-radius: 9999rpx;
  font-size: 24rpx;
  color: #5C544A;
}
.filter-chip.active {
  background: #FF7A00;
  color: #FFFFFF;
}

.section { margin-top: 32rpx; }
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.title-main { font-size: 34rpx; font-weight: 600; color: #1F1B16; }
.title-link { font-size: 24rpx; color: #FF7A00; }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }

.recipe-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(31, 27, 22, 0.06);
}
.card-cover {
  position: relative;
  width: 100%;
  height: 220rpx;
  background: linear-gradient(135deg, #FFE4CC 0%, #FFCCAA 100%);
}
.card-cover-img { width: 100%; height: 100%; }
.card-fav-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-fav-icon { width: 28rpx; height: 28rpx; }

.card-body { padding: 16rpx 20rpx 20rpx; }
.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1F1B16;
  margin-bottom: 6rpx;
}
.card-meta { font-size: 22rpx; color: #9B978F; }

.cat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.cat-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.cat-cover {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  margin-bottom: 12rpx;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cat-cover-img { width: 56rpx; height: 56rpx; }
.cat-label { font-size: 24rpx; color: #5C544A; }

.empty-tip {
  padding: 80rpx 0;
  text-align: center;
  color: #9B978F;
  font-size: 26rpx;
}

.my-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 27, 22, 0.06);
  overflow: hidden;
}
.my-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F4F2EE;
  gap: 16rpx;
}
.my-item:last-child { border-bottom: none; }
.my-icon { width: 36rpx; height: 36rpx; }
.my-text { flex: 1; font-size: 28rpx; color: #1F1B16; }
.my-count { font-size: 24rpx; color: #9B978F; }
.my-arrow { font-size: 28rpx; color: #BFBFBF; }
