.recipes-page {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 0 24rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 16rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.page-action {
  font-size: 26rpx;
  color: #FF6B1A;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #F5F6F8;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
}

.filter-scroll { white-space: nowrap; }
.filter-row { display: inline-flex; gap: 12rpx; padding: 8rpx 0 16rpx; }
.filter-chip {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: #F5F6F8;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #4A4A4A;
}
.filter-chip.active {
  background: #FF6B1A;
  color: #FFFFFF;
}

.section { margin-top: 24rpx; }
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.title-main { font-size: 32rpx; font-weight: 600; color: #1A1A1A; }
.title-link { font-size: 22rpx; color: #8C8C8C; }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }

.recipe-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.card-cover { width: 100%; height: 200rpx; }
.card-cover-img { width: 100%; height: 100%; }
.cover-emoji { font-size: 96rpx; }
.cover-emoji.small { font-size: 48rpx; }
.card-body { padding: 12rpx 16rpx 16rpx; }
.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}
.card-meta { font-size: 22rpx; color: #8C8C8C; }
.card-fav {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
  gap: 6rpx;
}
.fav-count { font-size: 22rpx; color: #8C8C8C; }

.cat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.cat-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.cat-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}
.cat-cover-img { width: 100%; height: 100%; }
.cat-label { font-size: 24rpx; color: #4A4A4A; }

.my-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.my-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  gap: 16rpx;
}
.my-item:last-child { border-bottom: none; }
.my-text { flex: 1; font-size: 28rpx; color: #1A1A1A; }
.my-count { font-size: 24rpx; color: #8C8C8C; }
.my-arrow { font-size: 28rpx; color: #BFBFBF; }

.bottom-spacer { height: 200rpx; }
