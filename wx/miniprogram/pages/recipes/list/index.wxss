.rl {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FAFAF8;
}

/* 顶部 */
.rl__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 12rpx;
}

.rl__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F1B16;
}

.rl__new {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 26rpx;
  background: #FFF6EE;
  border-radius: 9999rpx;
  color: #FF7A00;
  font-size: 26rpx;
  font-weight: 500;
}
.rl__new-icon { width: 28rpx; height: 28rpx; }

/* 搜索 */
.rl__search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0 32rpx 16rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 10rpx rgba(31, 27, 22, 0.04);
}
.rl__search-ic { width: 32rpx; height: 32rpx; opacity: 0.5; }
.rl__search-input { flex: 1; font-size: 28rpx; color: #1F1B16; }

/* 美团式两栏 */
.rl__body {
  flex: 1;
  display: flex;
  min-height: 0;
}

/* 左类目栏 */
.rl__side {
  width: 200rpx;
  background: #F4F2EE;
  height: 100%;
}

.rl__side-item {
  padding: 30rpx 20rpx;
  font-size: 27rpx;
  color: #5C544A;
  text-align: center;
  position: relative;
}

.rl__side-item--on {
  background: #FAFAF8;
  color: #FF7A00;
  font-weight: 600;
}

.rl__side-item--on::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: #FF7A00;
  border-radius: 0 6rpx 6rpx 0;
}

.rl__side-add {
  margin: 16rpx 16rpx;
  padding: 18rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #FF7A00;
  background: #FFF6EE;
  border: 1rpx dashed #FFBE8C;
  border-radius: 16rpx;
}

/* 右菜谱列 */
.rl__main {
  flex: 1;
  height: 100%;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

.rl__row {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(31, 27, 22, 0.05);
}

.rl__row-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FFE4CC 0%, #FFD0A8 100%);
  flex-shrink: 0;
}
.rl__row-cover-img { width: 100%; height: 100%; }

.rl__row-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.rl__row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B16;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rl__row-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9B978F;
}

.rl__row-actions {
  margin-top: auto;
  display: flex;
  gap: 16rpx;
}

.rl__row-btn {
  padding: 8rpx 28rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  background: #FFF6EE;
  color: #FF7A00;
}

.rl__row-btn--del {
  background: #FCEBE8;
  color: #E5604A;
}

.rl__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 120rpx 0;
  color: #9B978F;
  font-size: 26rpx;
}

.rl__empty-btn {
  padding: 16rpx 40rpx;
  background: #FF7A00;
  color: #FFFFFF;
  border-radius: 9999rpx;
  font-size: 26rpx;
}

.rl__main-spacer { height: 160rpx; }
