<view class="snap">
  <!-- 取景器 -->
  <view class="snap__viewfinder">
    <camera
      wx:if="{{!captured}}"
      class="snap__camera"
      device-position="{{devicePosition}}"
      flash="off"
      bindinitdone="onCameraReady"
      binderror="onCameraError"
    />
    <image wx:else class="snap__captured" src="{{capturedPath}}" mode="aspectFill" />

    <view class="snap__overlay"></view>

    <!-- 4 角括号 -->
    <view class="snap__bracket snap__bracket--tl">
      <view class="snap__bracket-h"></view>
      <view class="snap__bracket-v"></view>
    </view>
    <view class="snap__bracket snap__bracket--tr">
      <view class="snap__bracket-h"></view>
      <view class="snap__bracket-v"></view>
    </view>
    <view class="snap__bracket snap__bracket--bl">
      <view class="snap__bracket-h"></view>
      <view class="snap__bracket-v"></view>
    </view>
    <view class="snap__bracket snap__bracket--br">
      <view class="snap__bracket-h"></view>
      <view class="snap__bracket-v"></view>
    </view>

    <!-- 扫描线（识别中） -->
    <view wx:if="{{recognizing}}" class="snap__scanline"></view>

    <!-- 状态提示 -->
    <view wx:if="{{recognizing}}" class="snap__status-pill">
      <view class="snap__status-dot"></view>
      <text>识别中… 请保持画面清晰</text>
    </view>
    <view wx:elif="{{error}}" class="snap__error-box">
      <view class="snap__status-pill snap__status-pill--err">
        <text>⚠ {{error}}</text>
      </view>
      <view class="snap__error-actions">
        <view wx:if="{{captured}}" class="snap__error-btn" bindtap="onRetake">重拍</view>
        <view class="snap__error-btn snap__error-btn--primary" bindtap="onPickAlbum">从相册选图</view>
      </view>
    </view>
    <view wx:elif="{{!captured}}" class="snap__status-pill">
      <text>对准冰箱食材，点击下方拍照</text>
    </view>

    <!-- 顶部导航：统一 custom-navbar（叠加在取景画面上，白色标题） -->
    <custom-navbar overlay title="食材识别" color="#FFFFFF" />

    <!-- 底部操作行：快门 + 旁边的"结果"小按钮（默认状态：未拍） -->
    <view wx:if="{{!captured}}" class="snap__bottom-row">
      <view class="snap__side-slot"></view>
      <view class="snap__shutter" bindtap="onShutterTap">
        <view class="snap__shutter-inner"></view>
      </view>
      <view class="snap__side-slot">
        <view wx:if="{{chips.length}}" class="snap__result-pill" bindtap="onOpenSheet">
          <text class="snap__result-pill-num">{{chips.length}}</text>
          <text class="snap__result-pill-label">结果</text>
        </view>
      </view>
    </view>

    <!-- 拍摄完识别中 -->
    <view wx:if="{{captured && recognizing}}" class="snap__bottom-row">
      <view class="snap__side-slot"></view>
      <view class="snap__retake" bindtap="onRetake">
        <text>重拍</text>
      </view>
      <view class="snap__side-slot"></view>
    </view>

    <!-- 识别完成后底部：重拍 + 切换结果抽屉 -->
    <view wx:if="{{recognized && !recognizing}}" class="snap__bottom-row">
      <view class="snap__side-slot">
        <view class="snap__retake-mini" bindtap="onRetake">
          <text>重拍</text>
        </view>
      </view>
      <view class="snap__result-cta" bindtap="onToggleSheet">
        <text class="snap__result-cta-num">{{chips.length}}</text>
        <text class="snap__result-cta-label">{{sheetOpen ? '收起 ▾' : '查看结果 ▴'}}</text>
      </view>
      <view class="snap__side-slot"></view>
    </view>
  </view>

  <!-- 半透明蒙层：抽屉打开时点击关闭 -->
  <view wx:if="{{sheetOpen}}" class="snap__sheet-mask" bindtap="onCloseSheet"></view>

  <!-- 底部 sheet：默认收起，识别完自动展开 -->
  <view class="snap__sheet {{sheetOpen ? 'snap__sheet--open' : ''}}">
    <view class="snap__handle" bindtap="onCloseSheet"></view>
    <view class="snap__sheet-head">
      <text class="snap__sheet-title">识别结果</text>
      <view class="snap__count-chip">{{chips.length}} 种</view>
      <view wx:if="{{chips.length}}" class="snap__edit-hint">长按删除</view>
    </view>

    <view class="snap__chips">
      <view
        wx:for="{{chips}}"
        wx:key="id"
        class="snap__chip"
        data-id="{{item.id}}"
        bindlongpress="onChipLongpress"
      >
        <text class="snap__chip-emoji">{{item.emoji}}</text>
        <text class="snap__chip-name">{{item.name}}</text>
        <view class="snap__chip-del" data-id="{{item.id}}" catchtap="onChipDelete">×</view>
      </view>
      <view class="snap__chip snap__chip--add" bindtap="onChipAdd">+ 添加</view>
    </view>

    <view wx:if="{{!chips.length && !recognizing}}" class="snap__empty">点击拍照后等待识别…</view>

    <view class="snap__cta {{!chips.length ? 'snap__cta--disabled' : ''}}" bindtap="onGenerateTap">
      <text class="snap__cta-icon">✨</text>
      <text>生成推荐菜谱</text>
    </view>

    <text wx:if="{{chips.length}}" class="snap__hint">AI 将基于以上 {{chips.length}} 种食材为你智能推荐</text>
  </view>

  <!-- 添加食材弹层（替代已弃用的 wx.showModal editable） -->
  <input-dialog
    visible="{{addChipVisible}}"
    title="添加食材"
    placeholder="请输入食材名称"
    confirmText="添加"
    bind:confirm="onChipAddConfirm"
    bind:close="onChipAddClose"
  />
</view>
