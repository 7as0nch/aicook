.snap {
  min-height: 100vh;
  background: #1F1B16;
  display: flex;
  flex-direction: column;
}

/* ========== 取景器 ========== */
.snap__viewfinder {
  position: relative;
  flex: 1;
  min-height: 980rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #EEF0EA 0%, #D7DDD1 100%);
}

.snap__camera,
.snap__captured {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.snap__overlay {
  position: absolute;
  inset: 0;
  background: rgba(31, 27, 22, 0.14);
}

/* 4 角括号 — 200x200 居中（rpx：400x400） */
.snap__bracket {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
}

.snap__bracket-h {
  position: absolute;
  height: 10rpx;
  width: 64rpx;
  background: #FF7A00;
  border-radius: 5rpx;
}

.snap__bracket-v {
  position: absolute;
  width: 10rpx;
  height: 64rpx;
  background: #FF7A00;
  border-radius: 5rpx;
}

.snap__bracket--tl {
  top: 240rpx; left: 148rpx;
}
.snap__bracket--tl .snap__bracket-h { top: 0; left: 0; }
.snap__bracket--tl .snap__bracket-v { top: 0; left: 0; }

.snap__bracket--tr {
  top: 240rpx; right: 148rpx;
}
.snap__bracket--tr .snap__bracket-h { top: 0; right: 0; }
.snap__bracket--tr .snap__bracket-v { top: 0; right: 0; }

.snap__bracket--bl {
  bottom: 240rpx; left: 148rpx;
}
.snap__bracket--bl .snap__bracket-h { bottom: 0; left: 0; }
.snap__bracket--bl .snap__bracket-v { bottom: 0; left: 0; }

.snap__bracket--br {
  bottom: 240rpx; right: 148rpx;
}
.snap__bracket--br .snap__bracket-h { bottom: 0; right: 0; }
.snap__bracket--br .snap__bracket-v { bottom: 0; right: 0; }

/* 扫描线 */
.snap__scanline {
  position: absolute;
  top: 470rpx;
  left: 176rpx;
  width: 400rpx;
  height: 6rpx;
  background: rgba(255, 122, 0, 0.85);
  border-radius: 4rpx;
  animation: scan 1.6s ease-in-out infinite alternate;
}

@keyframes scan {
  0% { transform: translateY(-120rpx); }
  100% { transform: translateY(120rpx); }
}

/* 状态提示胶囊 */
.snap__status-pill {
  position: absolute;
  bottom: 220rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(31, 27, 22, 0.55);
  color: #FFFFFF;
  padding: 16rpx 28rpx;
  border-radius: 38rpx;
  font-size: 27rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  white-space: nowrap;
}

.snap__status-pill--err {
  background: rgba(229, 96, 74, 0.85);
}

.snap__status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2DBE7A;
}

/* 顶部按钮：右侧留出微信胶囊（约 180rpx 宽 + 14rpx 间距）避免重叠 */
.snap__topbar {
  position: absolute;
  left: 32rpx;
  right: calc(32rpx + 194rpx);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 10;
}

.snap__top-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.snap__top-icon {
  width: 36rpx;
  height: 36rpx;
}

.snap__top-emoji {
  font-size: 32rpx;
  color: #1F1B16;
}

/* 标题紧贴返回按钮，避开胶囊；不再 flex:1 居中（居中位置会被胶囊挡） */
.snap__top-title {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  flex: 1;
  text-align: left;
  margin-left: 4rpx;
}

.snap__top-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

/* 底部操作行：快门居中 + 左右两个 side slot 放辅助按钮 */
.snap__bottom-row {
  position: absolute;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 56rpx;
  z-index: 8;
}

.snap__side-slot {
  width: 144rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 快门按钮：单手友好下方居中 */
.snap__shutter {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
  border: 6rpx solid rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
}

.snap__shutter-inner {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #FFFFFF;
  transition: transform 0.1s ease, background 0.1s ease;
}

.snap__shutter:active .snap__shutter-inner {
  background: #FFE4CC;
  transform: scale(0.92);
}

/* 快门旁的小"结果"按钮（拍前可见，提示有现成 chip 可编辑） */
.snap__result-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.18);
}

.snap__result-pill-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF7A00;
  line-height: 1;
}

.snap__result-pill-label {
  font-size: 18rpx;
  color: #5C544A;
  margin-top: 2rpx;
}

/* 识别完成后底部：重拍 mini + 查看结果 CTA */
.snap__retake {
  padding: 22rpx 56rpx;
  background: rgba(31, 27, 22, 0.6);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 9999rpx;
  font-weight: 500;
}

.snap__retake-mini {
  padding: 16rpx 28rpx;
  background: rgba(31, 27, 22, 0.6);
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 9999rpx;
  font-weight: 500;
}

.snap__result-cta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 36rpx;
  background: #FFFFFF;
  color: #FF7A00;
  border-radius: 9999rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
}

.snap__result-cta-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.snap__result-cta-label {
  font-size: 28rpx;
}

/* ========== 底部 sheet（默认收起，识别完自动展开） ========== */
.snap__sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 19;
}

.snap__sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-top-left-radius: 56rpx;
  border-top-right-radius: 56rpx;
  padding: 24rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.15);
  z-index: 20;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
}

.snap__sheet--open {
  transform: translateY(0);
}

.snap__handle {
  width: 74rpx;
  height: 8rpx;
  background: #E2DED6;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.snap__sheet-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.snap__sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F1B16;
}

.snap__count-chip {
  background: #FFF6EE;
  color: #EF6E00;
  font-size: 23rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.snap__edit-hint {
  margin-left: auto;
  font-size: 22rpx;
  color: #9B978F;
}

/* chip 网格 */
.snap__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.snap__chip {
  position: relative;
  background: #FFF6EE;
  border: 2rpx solid #F4E6D3;
  color: #1F1B16;
  font-size: 27rpx;
  font-weight: 500;
  padding: 14rpx 36rpx 14rpx 24rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.snap__chip-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(31, 27, 22, 0.8);
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.snap__chip-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.snap__chip--add {
  background: #FFFFFF;
  border-color: #E6E2DA;
  color: #9B978F;
}

.snap__empty {
  color: #9B978F;
  text-align: center;
  font-size: 26rpx;
  padding: 24rpx 0;
}

.snap__cta {
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 54rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 20, 8, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.snap__cta--disabled {
  opacity: 0.5;
}

.snap__cta-icon {
  font-size: 32rpx;
}

.snap__hint {
  display: block;
  text-align: center;
  color: #9B978F;
  font-size: 25rpx;
  margin-top: 20rpx;
}

/* 错误态：提示 + 操作按钮（重拍 / 相册降级） */
.snap__error-box {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 280rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  z-index: 5;
}

.snap__error-actions {
  display: flex;
  gap: 20rpx;
}

.snap__error-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #1F1B16;
  font-size: 26rpx;
}

.snap__error-btn--primary {
  background: #FF7A00;
  color: #FFFFFF;
}
