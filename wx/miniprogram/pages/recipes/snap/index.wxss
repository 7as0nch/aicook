.snap-page {
  min-height: 100vh;
  background: #1A1A1A;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
}

.snap-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
}

.preview-area {
  flex: 1;
  background: #2A2A2A;
  border-radius: 24rpx;
  margin: 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  min-height: 600rpx;
}

.preview-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-tip {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-top: 24rpx;
}

.empty-sub {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 8rpx;
}

.preview-loaded {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.preview-mock {
  font-size: 200rpx;
}

.recog-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.recog-text {
  background: rgba(255, 107, 26, 0.9);
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.result-block {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.result-title {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
  gap: 8rpx;
}

.result-title text:first-child {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.result-count {
  font-size: 22rpx;
  color: #8C8C8C;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.result-chip {
  background: #FFF6EE;
  color: #FF6B1A;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.snap-actions {
  padding: 16rpx 0 calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.capture-btn {
  width: 100%;
  gap: 8rpx;
}

.action-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  opacity: 0.7;
}
