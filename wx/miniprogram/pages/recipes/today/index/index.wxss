.today {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 0 48rpx 220rpx;
}

.today__topbar {
  display: flex;
  align-items: center;
  padding: 24rpx 0 16rpx;
  gap: 16rpx;
}

.today__top-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF6EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.today__top-icon {
  width: 40rpx;
  height: 40rpx;
}

.today__top-spacer { flex: 1; }

.today__title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1F1B16;
  line-height: 1.1;
  margin-top: 24rpx;
}

.today__sub {
  font-size: 26rpx;
  color: #9B978F;
  margin-top: 14rpx;
}

.today__chips {
  width: 100%;
  white-space: nowrap;
  margin: 28rpx 0 0;
}

.today__chips-row {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.today__chip {
  background: #FFF6EE;
  color: #A9743A;
  font-size: 25rpx;
  padding: 10rpx 22rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.today__chip--extra {
  background: #F4F5F7;
  color: #9B978F;
}

.today__sort {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  margin-bottom: 24rpx;
}

.today__sort-tab {
  padding: 12rpx 24rpx;
  background: #F4F5F7;
  color: #6E6A62;
  font-size: 26rpx;
  border-radius: 32rpx;
}

.today__sort-tab--active {
  background: #FF7A00;
  color: #FFFFFF;
  font-weight: 500;
}

.today__list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.today__card {
  display: flex;
  background: #FFFFFF;
  border: 2rpx solid #EFEDE8;
  border-radius: 36rpx;
  padding: 22rpx;
  gap: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(31, 20, 8, 0.05);
}

.today__card-cover {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #FFEAD2 0%, #FFD6AA 100%);
  flex-shrink: 0;
  overflow: hidden;
}

.today__card-cover-img { width: 100%; height: 100%; }

.today__rank {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: #FF7A00;
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 8rpx;
  border-bottom-left-radius: 8rpx;
  border-bottom-right-radius: 20rpx;
}

.today__card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
  padding: 6rpx 0;
}

.today__card-line1 {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.today__card-title {
  font-size: 31rpx;
  font-weight: 600;
  color: #1F1B16;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.today__card-match {
  background: #E7F7EF;
  color: #2DBE7A;
  font-size: 23rpx;
  font-weight: 500;
  padding: 4rpx 18rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.today__card-meta {
  font-size: 24rpx;
  color: #9B978F;
}

.today__card-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 4rpx;
}

.today__card-tag {
  background: #FFF6EE;
  color: #A9743A;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}

.today__empty {
  text-align: center;
  color: #9B978F;
  padding: 80rpx 0;
  font-size: 26rpx;
}

.today__spacer { height: 60rpx; }
