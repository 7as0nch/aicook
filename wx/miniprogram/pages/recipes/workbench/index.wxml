<view class="wb">
  <custom-navbar title="生成菜谱" bg="#FFF6EE" />

  <!-- mascot + 提示 -->
  <view class="wb__hero">
    <image class="wb__hero-bao" src="/assets/mascot/bao-smile.png" mode="aspectFit" />
    <view class="wb__hero-bubble">
      <text>告诉我你想做什么菜，我来帮你生成完整菜谱</text>
    </view>
  </view>

  <!-- 输入区 -->
  <view class="wb__input-card">
    <textarea
      class="wb__textarea"
      placeholder="比如：用土豆和鸡蛋做一道下饭菜"
      placeholder-class="wb__ph"
      value="{{text}}"
      bindinput="onTextInput"
      maxlength="300"
      auto-height
    />
    <!-- 已上传图片 -->
    <view wx:if="{{images.length}}" class="wb__images">
      <view wx:for="{{images}}" wx:key="asset_id" class="wb__image">
        <image class="wb__image-img" src="{{item.url}}" mode="aspectFill" />
        <view class="wb__image-del" data-idx="{{index}}" catchtap="onRemoveImage">×</view>
      </view>
    </view>
    <!-- 工具按钮 -->
    <view class="wb__tools">
      <view class="wb__tool" bindtap="onPickImage">
        <image class="wb__tool-icon" src="/assets/icons/image.svg" mode="aspectFit" />
        <text>上传图片</text>
      </view>
      <view class="wb__tool {{recording ? 'wb__tool--active' : ''}}" bindtap="onVoiceTap">
        <image class="wb__tool-icon" src="/assets/icons/mic.svg" mode="aspectFit" />
        <text>{{recording ? '录音 ' + recordSeconds + 's · 点击结束' : '语音输入'}}</text>
      </view>
      <view class="wb__tool" bindtap="onSnapImport">
        <image class="wb__tool-icon" src="/assets/icons/camera.png" mode="aspectFit" />
        <text>拍照识别</text>
      </view>
    </view>
  </view>

  <!-- 流式状态预览 -->
  <view wx:if="{{streaming || answerPreview || statusLabel}}" class="wb__progress">
    <view wx:if="{{statusLabel}}" class="wb__progress-status">{{statusLabel}}</view>
    <view wx:if="{{answerPreview}}" class="wb__progress-text">{{answerPreview}}</view>
    <view wx:if="{{streaming}}" class="wb__progress-tip">
      <view class="wb__dots"><view></view><view></view><view></view></view>
      <text>生成中…</text>
    </view>
  </view>

  <!-- 生成失败提示 + 重试 -->
  <view wx:if="{{errorText && !streaming}}" class="wb__error">
    <text class="wb__error-text">⚠ {{errorText}}</text>
    <view class="wb__error-retry" bindtap="onRetry">重试</view>
  </view>

  <view class="wb__spacer"></view>

  <!-- 底部 CTA -->
  <view class="wb__cta-wrap">
    <view class="wb__cta {{(streaming || (!text && !images.length)) ? 'wb__cta--disabled' : ''}}" bindtap="onSubmit">
      <image class="wb__cta-icon" src="/assets/icons/send.svg" mode="aspectFit" />
      <text>{{streaming ? '生成中…' : '✨ AI 生成菜谱'}}</text>
    </view>
    <view class="wb__manual" bindtap="onManualCreate">想自己写？手动创建菜谱 ›</view>
  </view>
</view>

<!-- AI 需要补充选择（human-in-loop）时打开此抽屉作答，与本页共享同一会话 -->
<ai-sheet context="生成菜谱" />
