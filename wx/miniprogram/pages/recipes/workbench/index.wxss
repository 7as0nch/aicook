.wb {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF6EE 0%, #FFFFFF 50%);
  padding-bottom: 200rpx;
}

.wb__navbar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  padding-top: env(safe-area-inset-top);
  box-sizing: content-box;
  gap: 16rpx;
}

.wb__nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.wb__nav-icon { width: 36rpx; height: 36rpx; }

.wb__nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1B16;
  margin-right: 72rpx;
}

.wb__nav-placeholder { width: 0; }

.wb__hero {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 20rpx;
}

.wb__hero-bao { width: 120rpx; height: 120rpx; flex-shrink: 0; }

.wb__hero-bubble {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 24rpx 8rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 27, 22, 0.06);
  font-size: 28rpx;
  color: #1F1B16;
  line-height: 1.5;
}

.wb__input-card {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 27, 22, 0.06);
}

.wb__textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #1F1B16;
  line-height: 1.5;
}

.wb__ph { color: #BFBFBF; }

.wb__images {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.wb__image {
  position: relative;
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F4F5F7;
}

.wb__image-img { width: 100%; height: 100%; }

.wb__image-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.wb__tools {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F4F2EE;
}

.wb__tool {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: #FAFAF8;
  font-size: 22rpx;
  color: #5C544A;
}

.wb__tool--active { background: #FFF6EE; color: #FF7A00; }

.wb__tool-icon { width: 36rpx; height: 36rpx; }

.wb__progress {
  margin: 24rpx;
  padding: 28rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(31, 27, 22, 0.06);
}

.wb__progress-status {
  font-size: 24rpx;
  color: #FF7A00;
  margin-bottom: 12rpx;
}

.wb__progress-text {
  font-size: 28rpx;
  color: #1F1B16;
  line-height: 1.5;
  white-space: pre-wrap;
}

.wb__progress-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9B978F;
}

.wb__dots {
  display: flex;
  gap: 4rpx;
}

.wb__dots > view {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FF7A00;
  animation: wb-blink 1.2s infinite;
}

.wb__dots > view:nth-child(2) { animation-delay: 0.2s; }
.wb__dots > view:nth-child(3) { animation-delay: 0.4s; }

@keyframes wb-blink {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.wb__spacer { height: 120rpx; }

.wb__cta-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #F4F2EE;
}

.wb__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  background: #FF7A00;
  color: #FFFFFF;
  border-radius: 9999rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 0, 0.32);
}

.wb__cta--disabled {
  background: #DDD8D0;
  color: #FFFFFF;
  box-shadow: none;
}

.wb__cta-icon { width: 32rpx; height: 32rpx; filter: brightness(0) invert(1); }

/* 生成失败提示条 */
.wb__error {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 20rpx 48rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(229, 96, 74, 0.08);
  border: 2rpx solid rgba(229, 96, 74, 0.25);
  border-radius: 20rpx;
}

.wb__error-text {
  flex: 1;
  font-size: 25rpx;
  color: #E5604A;
  line-height: 1.5;
}

.wb__error-retry {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  background: #E5604A;
  color: #FFFFFF;
  font-size: 24rpx;
}

/* 手动创建入口 */
.wb__manual {
  text-align: center;
  margin-top: 20rpx;
  font-size: 25rpx;
  color: #9B978F;
  padding: 8rpx 0 4rpx;
}
