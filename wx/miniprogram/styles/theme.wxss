/**
 * AIcook 主题变量（对齐 UI 2.0 设计规范）
 * 主色：馋猫橙 #FF6B1A；辅助：浅橘 #FFF6EE / 中性灰底 #F5F6F8 / 成功绿 #2DBE7A
 */
page {
  /* 主色与辅助色 */
  --color-primary: #FF6B1A;          /* 主色 - 馋猫橙 */
  --color-primary-light: #FFA666;
  --color-primary-dark: #E55A0A;
  --color-primary-bg: #FFF6EE;       /* 主色淡背景 / 标签底 */
  --color-success: #2DBE7A;          /* 成功 / 食材充足 / 完成 */
  --color-success-bg: #E8F8EF;
  --color-warning: #FAAD14;
  --color-danger: #FF4D4F;
  --color-info: #1890FF;

  /* 文字色 */
  --color-text-primary: #1A1A1A;
  --color-text-regular: #4A4A4A;
  --color-text-secondary: #8C8C8C;
  --color-text-placeholder: #BFBFBF;
  --color-text-inverse: #FFFFFF;

  /* 背景 / 中性 */
  --color-bg-page: #FFFFFF;          /* 页面底白 */
  --color-bg-soft: #F5F6F8;          /* 聊天 / 卡片背景灰 */
  --color-bg-card: #FFFFFF;
  --color-bg-mask: rgba(0, 0, 0, 0.5);

  /* 边框 / 分割线 */
  --color-border: #EAEAEA;
  --color-divider: #F0F0F0;

  /* 圆角 */
  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;                /* 卡片默认 */
  --radius-xl: 32rpx;                /* 大卡片 / 抽屉顶圆 */
  --radius-pill: 999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(255, 107, 26, 0.12);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  --shadow-fab: 0 8rpx 24rpx rgba(255, 107, 26, 0.32);

  /* 字号（设计稿映射：rpx ≈ pt × 2） */
  --font-xs: 22rpx;                  /* 12pt Light - 说明 */
  --font-sm: 26rpx;                  /* 14pt Regular - 正文 */
  --font-md: 30rpx;
  --font-lg: 32rpx;                  /* 16pt Medium - 副标 */
  --font-xl: 40rpx;                  /* 22pt Semibold - 大标题 */
  --font-xxl: 56rpx;                 /* 30pt Bold - 主标题 */
}
